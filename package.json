{
  "name": "popop-rn",
  "version": "1.0.0",
  "main": "index.ts",
  "private": true,
  "scripts": {
    "start": "npm run typecheck && expo start",
    "start:lan": "npm run typecheck && expo start --host lan",
    "start:fast": "expo start",
    "dev": "expo start --dev-client --port 8082",
    "dev:lan": "expo start --dev-client --host lan",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "gen:api": "node scripts/gen-api.mjs",
    "idl:update": "git submodule update --remote external/common-idl",
    "sync:generated-from-fe": "node scripts/sync-generated-from-fe.mjs"
  },
