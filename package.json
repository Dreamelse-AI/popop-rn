  "devDependencies": {
    "@types/react": "~19.2.2",
    "ali-oss": "^6.23.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "^56.0.15",
    "eas-cli": "^20.2.0",
    "husky": "^9.1.7",
    "react-native-svg-transformer": "^1.5.3",
    "reactotron-react-native": "^5.2.0",
    "sharp": "^0.35.1",
    "svgo": "^4.0.1",
    "typescript": "~6.0.3"
  }
