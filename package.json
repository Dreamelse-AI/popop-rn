    "@react-navigation/native-stack": "^7.17.3",
    "expo": "~56.0.11",
    "expo-apple-authentication": "~56.0.4",
    "expo-audio": "~56.0.12",
    "expo-auth-session": "~56.0.14",
    "expo-build-properties": "^56.0.18",
    "expo-clipboard": "~56.0.4",
    "expo-constants": "~56.0.18",
    "expo-crypto": "~56.0.4",
