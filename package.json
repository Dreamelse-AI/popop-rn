{
  "name": "popop-rn",
  "version": "1.0.0",
  "main": "index.ts",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "expo start --dev-client",
    "dev:lan": "expo start --dev-client --host lan",
    "dev:clear": "expo start --dev-client --clear",
    "dev:kill": "node scripts/kill-metro.mjs",
    "dev:ios": "node scripts/dev-ios.mjs",
    "dev:android": "node scripts/dev-android.mjs",
    "ios:sim": "node scripts/dev-ios.mjs",
    "ios:sim:attach": "node scripts/dev-ios.mjs --attach",
    "ios:sim:rebuild": "node scripts/dev-ios.mjs --rebuild",
    "android:emu": "node scripts/android-emulator.mjs",
    "android:emu:list": "node scripts/android-emulator.mjs --list",
    "android:emu:setup": "node scripts/setup-android-emulator.mjs",
    "android:sim": "node scripts/dev-android-emulator.mjs",
    "android:sim:attach": "node scripts/dev-android-emulator.mjs --attach",
    "android:sim:build": "node scripts/run-android-emulator.mjs --no-bundler",
    "android:sim:rebuild": "node scripts/dev-android-emulator.mjs --rebuild",
    "android": "expo run:android",
    "android:device": "node scripts/dev-android.mjs",
    "android:device:attach": "node scripts/dev-android.mjs --attach",
    "android:device:build": "node scripts/run-android-device.mjs",
    "android:device:rebuild": "node scripts/dev-android.mjs --rebuild",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint src/",
    "test": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "gen:api": "node scripts/gen-api.mjs",
    "gen:api:update": "git submodule update --remote external/common-idl && node scripts/gen-api.mjs",
    "idl:update": "git submodule update --remote external/common-idl",
    "sync:generated-from-fe": "node scripts/sync-generated-from-fe.mjs",
    "sync:i18n-from-fe": "node scripts/sync-i18n-from-fe.mjs",
    "eas": "eas",
    "compress:assets": "node scripts/compress-assets.mjs",
    "cdn:sync": "node scripts/cdn/sync.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.18.0",
    "@react-navigation/native": "^7.3.1",
    "@react-navigation/native-stack": "^7.17.3",
    "expo": "~56.0.11",
    "expo-apple-authentication": "~56.0.4",
    "expo-audio": "~56.0.12",
    "expo-auth-session": "~56.0.14",
    "expo-build-properties": "^56.0.18",
    "expo-clipboard": "~56.0.4",
    "expo-constants": "~56.0.18",
    "expo-crypto": "~56.0.4",
    "expo-dev-client": "^56.0.20",
    "expo-file-system": "~56.0.8",
    "expo-iap": "^4.3.1",
    "expo-image": "~56.0.11",
    "expo-image-picker": "~56.0.17",
    "expo-linear-gradient": "^56.0.4",
    "expo-localization": "~56.0.6",
    "expo-media-library": "^56.0.7",
    "expo-secure-store": "~56.0.4",
    "expo-speech-recognition": "^56.0.1",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-web-browser": "~56.0.5",
    "i18next": "^26.3.1",
    "react": "19.2.3",
    "react-i18next": "^17.0.8",
    "react-native": "0.85.3",
    "react-native-mmkv": "^4.3.1",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-screens": "^4.25.2",
    "react-native-svg": "^15.15.5",
    "react-native-webview": "^13.16.1",
    "simple-icons": "^16.23.0",
    "zustand": "^5.0.5"
