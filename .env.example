# 复制为 .env.local 后填入真实值（.env.local 已在 .gitignore 中）

# API 根地址（可选）
# API_BASE_URL=https://api.popop.dev

# 请求签名密钥（勿提交）
# API_SIGN_SECRET=your-secret

# 本地开发自动登录 token（仅 __DEV__ 生效，永不过期）
# 将 xxx 替换为真实 JWT
# DEV_AUTH_TOKEN=xxx

# Mock 配置（改后需重启 Metro）
# 覆盖 ip_region / 设备地区（JP | KR | US | GB/UK | TW | HK | CN；默认 US；off 关闭）
# MOCK_DEVICE_REGION=US
# MOCK_NEW_USER=false
# MOCK_CHARACTER_POSTS=false
# CHARACTER_CREATION_USE_MOCK=false
# PREVIEW_PUBLISH_SUCCESS_MODAL=false

# Stripe（充值等，可选）
# STRIPE_PUBLISHABLE_KEY=pk_test_...

# Metro 端口（可选，默认 iOS 8081 / Android 8082，可同时开两个模拟器互不干扰）
# IOS_METRO_PORT=8081
# ANDROID_METRO_PORT=8082
