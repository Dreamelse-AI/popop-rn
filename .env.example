# 复制为 .env.local 后填入真实值（.env.local 已在 .gitignore 中）

# API 根地址（可选）
# API_BASE_URL=https://i18n-api.imaginewithu.com

# 请求签名密钥（勿提交）
# API_SIGN_SECRET=your-secret

# 本地开发自动登录 token（仅 __DEV__ 生效，永不过期）
# 将 xxx 替换为真实 JWT
# DEV_AUTH_TOKEN=xxx

# Mock 配置（改后需重启 Metro）
# 覆盖设备地区兜底；/app/ip_region 无返回值或请求失败时，X-Region 将据此映射（如 KR → X-Region: KR）
# MOCK_DEVICE_REGION=KR
# MOCK_NEW_USER=false
# MOCK_CHARACTER_POSTS=false
# CHARACTER_CREATION_USE_MOCK=false
# PREVIEW_PUBLISH_SUCCESS_MODAL=false

# Stripe（充值等，可选）
# STRIPE_PUBLISHABLE_KEY=pk_test_...

# Metro 端口（可选，默认 iOS 8081 / Android 8082，可同时开两个模拟器互不干扰）
# IOS_METRO_PORT=8081
# ANDROID_METRO_PORT=8082
