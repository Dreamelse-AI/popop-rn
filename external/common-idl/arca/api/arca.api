type FeedMoreCharactersReq {
	RequestId        *string  `json:"request_id,optional"`
	Strategy         string   `json:"strategy"` // 召回策略
	SeedCharacterIds []string `json:"seed_character_ids"` // 召回的种子character
	Limit            *int     `json:"limit,optional,omitempty"` // 每页条目数，默认 10
