type PlayAchievement {
	Title string `json:"title"`
	Count int    `json:"count"`
	Event string `json:"event,options=ending|achievement"`
// Desc  string `json:"desc"`
}

type PlayEntity {
	PlayId           string             `json:"play_id"`
	Title            string             `json:"title"` // 剧本标题
	Tags             []string           `json:"tags"` // 标签数组
	CornerTag        string             `json:"corner_tag"` // 左上标签
	BkgMedia         *Media             `json:"bkg_media,optional"` // 背景图
	BkgMainColor     *string            `json:"bkg_main_color,optional"` // 背景图主色
	AppearanceMedias []*Media           `json:"appearance_medias,optional"` // 人物形象图
	ActCount         int                `json:"act_count"` // 章节数量
	Achievements     []*PlayAchievement `json:"achievements"` // 剧本成就
	ScriptId         string             `json:"script_id"` // 剧本Id
	Version          string             `json:"version"` // 版本号
	PlayRoleId       *string            `json:"play_role_id,optional"` // 用户玩的角色
	LastPlayTime     *int64             `json:"last_play_time,optional"` // 最后游玩时间
}

type GetUserHomePageStatReq {}

