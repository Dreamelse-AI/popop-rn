syntax = "v1"

// WalletStatusInfo 钱包状态软提醒：随各扣代币场景的成功响应回传。
// balance=可用代币合计（免费币+付费币）；low_balance=剩余可消费次数低于阈值 → 前端限时气泡提示充值。
// 阻断态（余额不足）走业务错误码（统一 40402），不在此结构。
type WalletStatusInfo {
	Balance    int64 `json:"balance"`
	LowBalance bool  `json:"low_balance"`
}

type AppLoginRedirectRequest {
	Code  string `form:"code"` // OAuth2.0 授权码
	State string `form:"state"` // 用于防止CSRF攻击的状态值
}

type AppLoginRedirectResponse {
	JwtToken  string `json:"jwt_token"` // 业务JWT令牌
	ExpiresIn int64  `json:"expires_in"` // JWT令牌过期时间（秒）
}

// [DEPRECATED 2026-05-28] 手机号验证码登录/注册已废弃；type 与接口注释保留以备恢复。
// type SendCodeReq {
//  PhoneNumber string `json:"phone_number"`
//  Scene       string `json:"scene,options=login|deregister"`
// }
// type SendCodeResp {
//  Message    string   `json:"message"`
//  RequestId  string   `json:"request_id"`
//  MessageIds []string `json:"message_ids"`
// }
// type VerifyCodeReq {
//  PhoneNumber   string  `json:"phone_number"`
//  Code          string  `json:"code"`
//  Scene         string  `json:"scene,options=login|deregister"`
//  TempAuthToken *string `json:"temp_auth_token,optional,omitempty"`
// }
// type VerifyCodeResp {
//  IsValid   bool   `json:"is_valid"`
//  Message   string `json:"message"`
//  RequestId string `json:"request_id,optional"`
//  JwtToken  string `json:"jwt_token,optional"`
//  ExpiresIn int    `json:"expires_in,optional"`
// }
// 三方 + Apple 登录统一请求：provider 走 path 参数。
// Google/Apple：前端 SDK 直接拿 id_token，传 id_token + nonce。
// LINE/Kakao：authorization code flow，前端传 code + nonce + redirect_uri，后端用 secret 换 id_token 再验签。
// 后端按 provider 走 OIDCVerifier 本地 JWKS 验签（Apple 已 OIDC 标准化，与三家同构）。
type OAuthSessionReq {
	Provider    string `path:"provider"` // google | line | kakao | apple
	IdToken     string `json:"id_token,optional"` // Google/Apple：前端拿到的 id_token
	Nonce       string `json:"nonce"` // 防重放，须与 id_token 内 nonce 一致
	Code        string `json:"code,optional"` // LINE/Kakao：authorization code
	RedirectURI string `json:"redirect_uri,optional"` // LINE/Kakao：与前端 authorize 时一致，换 token 用
}

// 登录统一响应：验签通过直发正式 JWT（平铺，无嵌套层）。
type LoginResp {
	JwtToken  string `json:"jwt_token"`
	ExpiresIn int64  `json:"expires_in"`
	IsNew     bool   `json:"is_new"` // 本次登录是否新注册用户
}

// 邮箱验证码：请求发码。Language 取自 HTTP 头 X-Language（en | ko | zh-Hant，兜底 en），决定邮件正文语言。
type EmailCodeReq {
	Email    string `json:"email"`
	Language string `header:"X-Language,optional"`
}

// 邮箱发码响应。
type EmailCodeResp {
	Message string `json:"message"`
}

// 邮箱验证码：验码并登录（成功复用 LoginResp）。
type EmailSessionReq {
	Email string `json:"email"`
	Code  string `json:"code"`
}

type TOSObject {
	BucketName  string  `json:"bucket_name"` // 所属存储桶名称
	ObjectKey   string  `json:"object_key"` // 对象在存储桶中的唯一键
	ObjectType  string  `json:"object_type"` // 对象类型: video/image/音频
	RequestId   string  `json:"request_id,optional"` // 可选，请求ID，用于跟踪请求
	Url         string  `json:"url,optional"` // 可选，对象URL，用于直接访问对象
	Face        *Rect   `json:"face,optional"` // 脸部定位框（可选，仅 AIGC 生成的图片会带）
	Description *string `json:"description,optional"` // 资源描述（AIGC 上游返回的 description，前端透传）
}

// ==================== 运营侧画风配置接口类型 ====================
// 运营侧画风配置项（包含ID）
type OpsStylePromptItem {
	Id          int64  `json:"id"` // 主键ID
	StyleName   string `json:"style_name"` // 画风名称
	StyleIcon   string `json:"style_icon"` // 画风icon的URL
	StylePrompt string `json:"style_prompt"` // 画风prompt内容
	Priority    int    `json:"priority"` // 优先级，越大优先级越高
	Status      int    `json:"status"` // 状态枚举，1-有效/2-失效
	CreatedAt   string `json:"created_at"` // 创建时间
	UpdatedAt   string `json:"updated_at"` // 更新时间
}

// 列出画风配置响应
type ListStylePromptResp {
	Items []OpsStylePromptItem `json:"items"` // 画风配置列表（按优先级降序）
}

// 新增画风配置请求
type CreateStylePromptReq {
	StyleName   string `json:"style_name"` // 画风名称（必填）
	StyleIcon   string `json:"style_icon"` // 画风icon的URL（可选）
	StylePrompt string `json:"style_prompt"` // 画风prompt内容（可选）
	Priority    int    `json:"priority"` // 优先级（必填）
}

// 新增画风配置响应
type CreateStylePromptResp {
	Id int64 `json:"id"` // 新增的画风配置ID
}

// 修改画风配置请求
type UpdateStylePromptReq {
	Id          int64  `json:"id"` // 主键ID（必填）
	StyleName   string `json:"style_name"` // 画风名称（可选）
	StyleIcon   string `json:"style_icon"` // 画风icon的URL（可选）
	StylePrompt string `json:"style_prompt"` // 画风prompt内容（可选）
	Priority    int    `json:"priority"` // 优先级（可选）
}

// 修改画风配置响应
type UpdateStylePromptResp {}

// 删除画风配置请求
type DeleteStylePromptReq {
	Id int64 `json:"id"` // 主键ID（必填）
}

// 删除画风配置响应
type DeleteStylePromptResp {}

// 肉体配置选项
type BodyConfigResp {
	Genders       []string               `json:"genders"` // 性别选项：男/女/其他（中文原文，作内部 key 用）
	GendersName   []string               `json:"genders_name"` // 性别展示名（按 X-Language 翻译，与 genders 一一对应）
	Species       []string               `json:"species"` // 物种选项：人类/其他（中文原文，作内部 key 用）
	SpeciesName   []string               `json:"species_name"` // 物种展示名（按 X-Language 翻译，与 species 一一对应）
	Relationships []CharacterRelation    `json:"relationships"` // 关系选项列表（包含关系名称、描述等）
	ArtStyles     []*AppearanceStyleItem `json:"art_styles"` // 画风选项列表（包含名称和图标）
	SoulWords     []SoulWordOption       `json:"soul_words"` // 灵魂词可选项（含颜色/素材等配置）
}

// 灵魂词可选项（来自 config_character_ability）
type SoulWordOption {
	SoulWord           string   `json:"soul_word"` // 灵魂词（ability_name）
	SoulWordEmoji      string   `json:"soul_word_emoji"` // 灵魂词表情（soul_word_emoji）
	SoulWordDesc       string   `json:"soul_word_desc,optional"` // 描述（ability_desc）
	Priority           int64    `json:"priority,optional"` // 优先级（越大越靠前）
	CenterColor        string   `json:"center_color,optional"` // 中心颜色值（如 #FFF4B4）
	TransitionColor    string   `json:"transition_color,optional"` // 过渡颜色值
	EdgeColor          string   `json:"edge_color,optional"` // 边缘颜色值
	EmotionResourceId  string   `json:"emotion_resource_id,optional"` // 表情素材资源ID（resource_media）
	EmotionResourceUrl string   `json:"emotion_resource_url,optional"` // 表情素材资源URL（TOS URL）
	HighestEvaluations []string `json:"highest_evaluations,optional"` // 最高评价（字符串数组）
	LowestEvaluations  []string `json:"lowest_evaluations,optional"` // 最低评价（字符串数组）
}

// 灵魂词配置项
type SoulWordConfig {
	SoulWord string `json:"soul_word"` // 灵魂词
	WordType int32  `json:"word_type,options=1|2"` // 1: 平台词 2: 自定义词
	Strength int    `json:"strength"` // 强度
}

// 查询灵魂词评论请求
type GetSoulWordEvaluationReq {
	Abilities []SoulWordAbilityInput `json:"abilities"` // 灵魂词能力数组
}

// 灵魂词能力输入
type SoulWordAbilityInput {
	AbilityName  string `json:"ability_name"` // 灵魂词名称
	AbilityValue int    `json:"ability_value"` // 能力值
}

// 查询灵魂词评论响应
type GetSoulWordEvaluationResp {
	Evaluation string `json:"evaluation"` // 综合评价文本
}

// 日程信息
type CharacterSchedule {
	ScheduleId            string `json:"schedule_id"` // 日程全局ID
	CharacterId           string `json:"character_id,optional"` // 角色ID
	ScheduleName          string `json:"schedule_name,optional"` // 日程名称
	ScheduleStartTime     string `json:"schedule_start_time,optional"` // 日程开始时间
	ScheduleEndTime       string `json:"schedule_end_time,optional"` // 日程结束时间
	EventType             string `json:"event_type,optional"` // 事件类型(常规/突发)
	CharacterState        string `json:"character_state,optional"` // 角色状态
	CharacterLoc          string `json:"character_loc,optional"` // 角色地点
	CharacterLocBkg       *Media `json:"character_loc_bkg,optional,omitempty"` // 角色地点的背景
	CurrentOutfitId       string `json:"current_outfit_id,optional"` // 当前皮肤ID，用于 list 展示角色图
	CurrentAppearanceName string `json:"current_appearance_name,optional"` // 当前动作名，用于 list 展示角色图
	Detail                string `json:"detail,optional"` // 日程详情
	Viewed                bool   `json:"viewed,optional"` // 是否被观看 true:已读 false:未读
	HasPaid               int    `json:"has_paid,optional"` // 是否已支付
}

// 角色搜索关键信息
type CharacterListPageBasicInfo {
	CharacterId    string             `json:"character_id"` // 角色全局ID
	Name           string             `json:"name,optional"` // 角色名称
	Aka            string             `json:"aka,optional"` // 角色称号，可选
	Image          Media              `json:"image,optional"` // 角色形象
	BkgMainColor   *string            `json:"bkg_main_color,optional"`
	CustomRelation *CharacterRelation `json:"custom_relation,optional"` // 用户填写的自制关系（来自 character 表 relationship + impression_to_user）
	LikeCount      int64              `json:"like_count"`
	IsLiked        bool               `json:"is_liked,optional"` // 当前用户是否已点赞
}

// 角色当前状态
type CharacterStatus {
	CharacterState         string  `json:"character_state,optional"` // 角色状态
	CharacterLoc           string  `json:"character_loc,optional"` // 角色地点
	CharacterLocBkg        *Media  `json:"character_loc_bkg,optional,omitempty"` // 角色地点的背景
	BkgMainColor           *string `json:"bkg_main_color,optional,omitempty"` // 优先选人物的主色
	CurrentOutfitId        string  `json:"current_outfit_id,optional"` // 当前皮肤ID，用于 list 展示角色图
	CurrentAppearanceName  string  `json:"current_appearance_name,optional"` // 当前动作名，用于 list 展示角色图
	CurrentAppearanceMedia *Media  `json:"current_appearance_media,optional"` //
}

// 角色关键信息
type CharacterPageBasicInfo {
	BasicInfo       CharacterListPageBasicInfo `json:"basic_info"` // 角色基础信息
	CurrentStatus   CharacterStatus            `json:"character_status"` // 角色当前状态
	CurrentSchedule *CharacterSchedule         `json:"current_schedule,optional"` // 角色最新日程（最新一条）
	LatestMessage   *PhoneMessageOutput        `json:"latest_message,optional"` // 小手机最新一条消息
	LatestMessages  []*PhoneMessageOutput      `json:"latest_messages,optional"` // 小手机最新多条消息
	UnreadCount     int                        `json:"unread_count"` // 未读消息数
	PinnedAt        int64                      `json:"pinned_at,optional"` // 0 表示未置顶
	LastActiveAt    int64                      `json:"last_active_at,optional"`
	IsNew           bool                       `json:"is_new,optional"` // 0 表示未置顶
	RelationTag     string                     `json:"relation_tag,optional"` // 关系标签（如：闺蜜、舔狗等）
	Scale           *float32                   `json:"scale,optional"` // 缩放尺寸
}

type FriendshipBasicInfo {
	FriendshipId              string                `json:"friendship_id"`
	CurrentCharacterSaveId    string                `json:"current_character_save_id"`
	CharacterId               string                `json:"character_id"` // 角色全局ID
	CurrentCharacterVersionNo int32                 `json:"current_character_version_no"` // 当前存档绑定的角色版本号（character_version.version_no）
	LatestCharacterVersionNo  int32                 `json:"latest_character_version_no"` // 该角色最新版本号；与 current 不同说明有新版本可更新
	Name                      string                `json:"name,optional"` // 角色名称
	Aka                       string                `json:"aka,optional"` // 角色称号，可选
	Avatar                    Media                 `json:"avatar,optional"` // 角色头像
	BkgMainColor              *string               `json:"bkg_main_color,optional"`
	UnreadCount               int                   `json:"unread_count"` // 未读消息数
	PinnedAt                  int64                 `json:"pinned_at,optional"` // 0 表示未置顶
	LastActiveAt              int64                 `json:"last_active_at,optional"`
	IsNew                     bool                  `json:"is_new,optional"` // 0 表示未置顶
	LatestMessages            []*PhoneMessageOutput `json:"latest_messages,optional"` // 小手机最新多条消息
	CurrentStatus             CharacterStatus       `json:"current_status"` // 角色当前状态
}

// 预留音色相关结构
type VoiceTone {
	VoiceId string `json:"id"` // 音色ID
	Name    string `json:"name"` // 音色名称
	Icon    Media  `json:"icon,optional"` // 音色图标
	Desc    string `json:"desc,optional"` // 音色描述（可选）
	Sample  Media  `json:"sample,optional"` // 示例试听（可选）
}

type Point {
	X int `json:"x"`
	Y int `json:"y"`
}

type Rect {
	LeftTop    Point `json:"left_top"`
	RightBttom Point `json:"right_bottom"`
}

// 多媒体资源结构
type Media {
	Id        string `json:"id"` // resource_media表的resource_media_id（输入时可选，输出时由服务端填充）
	Name      string `json:"name,optional"` // 资源名（可选）
	Url       string `json:"url"` // 资源链接（必选）
	Width     int    `json:"width,optional"` // 资源宽度
	Height    int    `json:"height,optional"` // 资源高度
	Duration  int    `json:"duration,optional"` // 时长（可选，单位毫秒）
	MediaType string `json:"media_type"` // 资源类型（如 image/video/audio/...）
	Desc      string `json:"desc,optional"` // 资源描述
	Face      *Rect  `json:"face,optional"` // 脸部定位
	Text      string `json:"text,optional"` // 文本描述
}

// ==================== 小手机互动消息类型定义 ====================
// 文本消息内容（msg_type = 'text'）
type PhoneMessageText {
	Text string `json:"text"` // 文本内容
}

// 语音消息内容（msg_type = 'voice'）
type PhoneMessageVoice {
	Voice Media  `json:"voice"` // 语音资源，media_type 应为 'audio'
	Text  string `json:"text,optional"` // 语音转文字的文本内容
}

// 图片消息内容（msg_type = 'image'）
type PhoneMessageImage {
	Image Media `json:"image"` // 图片资源，media_type 应为 'image'
}

// 表情消息内容（msg_type = 'emoji'）
type PhoneMessageEmoji {
	EmojiId string `json:"emoji_id"` // 表情ID（旧情绪表情或新表情包体系的 emoji_id）
	Source  string `json:"source,optional"` // 来源：emotion(旧情绪表情)/platform(平台表情包)/user(用户上传)，可选
	PackId  string `json:"pack_id,optional"` // 所属平台表情包ID（source=platform 时），可选
	Media   Media  `json:"media,optional,omitempty"` // 表情图片资源（可空，服务端可按 emoji_id 重解析）
}

// 输入类型的消息子结构（统一使用 Media 结构，简化类型定义并统一输入输出结构）
// 相比之前的 TOSObject，Media 结构更简洁，且与输出结构一致
type PhoneMessageTextInput {
	Text string `json:"text"` // 文本内容
}

type PhoneMessageFriendRequestInput {
	Prologues []string `json:"prologues"` // 开场白
	Accept    *bool    `json:"accept,optional,omitempty"`
}

type PhoneMessageVoiceInput {
	Voice Media  `json:"voice"` // 语音资源（Media 结构，url 必填，width/height/duration 可选）
	Text  string `json:"text,optional"` // 语音转文字的文本内容
}

type PhoneMessageImageInput {
	Image Media `json:"image"` // 图片资源（Media 结构，url 必填，width/height 可选）
}

type PhoneMessageGiftInput {
	Name        string         `json:"name"` // 礼物名称
	Description string         `json:"description"` // 礼物描述
	Price       int            `json:"price"` // 礼物价格
	Image       GiftImageInput `json:"image"` // 礼物图片（可以是礼物图片或emoji）
	Status      string         `json:"status"` // 礼物状态：'sent'（已发送，发送方视角）或 'received'（已接收，接受方视角）
}

type GiftImageInput {
	Type    string `json:"type"` // 类型：'gift_image' 或 'emoji'
	Media   *Media `json:"media,optional"` // 礼物图片资源（当 type 为 'gift_image' 时使用，Media 结构）
	EmojiId string `json:"emoji_id,optional"` // 表情ID（当 type 为 'emoji' 时使用）
}

// 礼物图片资源（可以是礼物图片或emoji）
type GiftImage {
	Type    string `json:"type"` // 类型：'gift_image' 或 'emoji'
	Media   *Media `json:"media,optional"` // 礼物图片资源（当 type 为 'gift_image' 时使用）
	EmojiId string `json:"emoji_id,optional"` // 表情ID（当 type 为 'emoji' 时使用）
}

// 礼物消息内容（msg_type = 'gift'）
type PhoneMessageGift {
	Name        string    `json:"name"` // 礼物名称
	Description string    `json:"description"` // 礼物描述
	Price       int       `json:"price"` // 礼物价格
	Image       GiftImage `json:"image"` // 礼物图片（可以是礼物图片或emoji）
	Status      string    `json:"status"` // 礼物状态：'sent'（已发送，发送方视角）或 'received'（已接收，接受方视角）
}

// 邀约消息内容（msg_type = 'invitation'）
type PhoneMessageInvitation {
	InvitationId string `json:"invitation_id"` // 邀约ID
	ScheduleId   string `json:"schedule_id,optional"` // 关联的日程ID（可选）
	Title        string `json:"title,optional"` // 邀约标题（可选）
	Description  string `json:"description,optional"` // 邀约描述（可选）
	ButtonLabel  string `json:"button_label,optional"` // 按钮标签
	Location     string `json:"location,optional"` // 地点名称
	LocationId   string `json:"location_id,optional"` // 地点ID
	Outfit       string `json:"outfit,optional"` // 服装ID
	Emotion      string `json:"emotion,optional"` // 情绪ID
	Status       string `json:"status,optional"` // 状态文字
}

// HTML文件消息内容（msg_type = 'html_file'）
type PhoneMessageHtml {
	HtmlFile Media `json:"html_file"` // HTML文件资源
}

// 合并转发消息内容（msg_type = 'forward'）
// 类比微信/QQ 的"合并转发"：一条消息里嵌套多条原始消息
// Items 是已被 hydrated 的条目（服务端拼好后返回给客户端直接渲染，不需要二次请求）
type PhoneMessageForward {
	Title   string              `json:"title"` // 合并转发标题，如 "和小明的聊天记录"
	Source  string              `json:"source,optional"` // 来源描述，如 "张三,李四,王五"
	Summary string              `json:"summary,optional"` // 列表页预览文案（若干条原消息拼接，客户端列表气泡一行展示）
	Count   int                 `json:"count"` // 条目总数（Items 可能只包含前 N 条预览，Count 是完整总数）
	Items   []*PhoneForwardItem `json:"items"` // 嵌套消息列表（按发送时间升序）
	Cover   *Media              `json:"cover"`
}

// 合并转发里的一条嵌套消息；与 PhoneMessageOutput 结构同构，去掉会话级字段（is_read/is_click/cursor 等）
type PhoneForwardItem {
	MessageId    string                  `json:"message_id,optional,omitempty"` // 原消息 id（可选，用于客户端跳转回原消息）
	SenderName   string                  `json:"sender_name"` // 原发送者展示名
	SenderAvatar *Media                  `json:"sender_avatar,optional,omitempty"` // 原发送者头像
	MsgDirection string                  `json:"msg_direction,optional,omitempty"` // 'user'/'character'/'system'
	MsgType      string                  `json:"msg_type"` // 原消息类型：'text'/'voice'/'image'/'gift'/'emoji'/'invitation'/'html_file'/'forward'（支持嵌套合并）
	Text         *PhoneMessageText       `json:"text,optional,omitempty"`
	Voice        *PhoneMessageVoice      `json:"voice,optional,omitempty"`
	Image        *PhoneMessageImage      `json:"image,optional,omitempty"`
	Emoji        *PhoneMessageEmoji      `json:"emoji,optional,omitempty"`
	Gift         *PhoneMessageGift       `json:"gift,optional,omitempty"`
	Invitation   *PhoneMessageInvitation `json:"invitation,optional,omitempty"`
	HtmlFile     *PhoneMessageHtml       `json:"html_file,optional,omitempty"`
	Forward      *PhoneMessageForward    `json:"forward,optional,omitempty"` // 嵌套合并转发
	CreatedAt    int64                   `json:"created_at"` // 原消息时间戳（毫秒）
}

// 合并转发输入结构（用于请求）
// 客户端勾选源 session 里若干条消息，传 origin_msg_ids + origin_session_id；
// 服务端校验所有权 + 读取原消息 + hydrate 成 PhoneMessageForward 落库
type PhoneMessageForwardInput {
	Title            string   `json:"title,optional"` // 覆盖默认标题；空则服务端按来源生成
	Cover            *Media   `json:"media"`
	OriginTargetId   string   `json:"origin_target_id"` // 被转发消息所在的源 session_id（群聊）
	OriginTargetType string   `json:"origin_target_type,options=character"` // 被转发消息所在的源 session_id（群聊）
	OriginMsgIds     []string `json:"origin_msg_ids"` // 被勾选的原消息 id 列表，按原顺序（长度上限由服务端限定，如 50 条）
}

// 小手机消息输入结构（用于请求）
// 注意：Voice 和 Image 输入统一使用 Media 结构（而非 TOSObject），简化类型定义并统一输入输出结构
// Media 中的 url 必填，width/height/duration 等元信息可选（客户端如果知道可以传，不知道则服务端后续可补充）
type PhoneMessageInput {
	MsgType       string                          `json:"msg_type"` // 消息类型：'text'/'voice'/'image'/'gift'/'emoji'/'invitation'/'forward'
	Text          *PhoneMessageTextInput          `json:"text,optional"` // 文本消息内容（当 msg_type = 'text' 时使用）
	Voice         *PhoneMessageVoiceInput         `json:"voice,optional"` // 语音消息内容（当 msg_type = 'voice' 时使用）
	Image         *PhoneMessageImageInput         `json:"image,optional"` // 图片消息内容（当 msg_type = 'image' 时使用）
	Emoji         *PhoneMessageEmoji              `json:"emoji,optional"` // 表情消息内容（当 msg_type = 'emoji' 时使用）
	Gift          *PhoneMessageGiftInput          `json:"gift,optional"` // 礼物消息内容（当 msg_type = 'gift' 时使用）
	Invitation    *PhoneMessageInvitation         `json:"invitation,optional"` // 邀约消息内容（当 msg_type = 'invitation' 时使用）
	MediaForward  *PhoneMessageForwardInput       `json:"media_forward,optional"` // 合并转发（当 msg_type = 'forward' 时使用）
	FriendRequest *PhoneMessageFriendRequestInput `json:"friend_request,optional"` // 好友请求/回应好友请求
}

// internal/viewer 展示的 LLM 输入输出追溯信息
type ViewerLLMTrace {
	RequestId         string `json:"request_id,optional,omitempty"`
	PlayCallId        string `json:"play_call_id,optional,omitempty"`
	Route             string `json:"route,optional,omitempty"`
	TraceId           string `json:"trace_id,optional,omitempty"`
	SpanId            string `json:"span_id,optional,omitempty"`
	Provider          string `json:"provider,optional,omitempty"`
	Model             string `json:"model,optional,omitempty"`
	Mode              string `json:"mode,optional,omitempty"`
	ProviderRequestId string `json:"provider_request_id,optional,omitempty"`
	FinishReason      string `json:"finish_reason,optional,omitempty"`
	PromptTokens      int64  `json:"prompt_tokens,optional,omitempty"`
	CompletionTokens  int64  `json:"completion_tokens,optional,omitempty"`
	TotalTokens       int64  `json:"total_tokens,optional,omitempty"`
	ThinkingTokens    int64  `json:"thinking_tokens,optional,omitempty"`
	RequestSummary    string `json:"request_summary,optional,omitempty"`
	RequestPayload    string `json:"request_payload,optional,omitempty"`
	ResponseSummary   string `json:"response_summary,optional,omitempty"`
	ResponsePayload   string `json:"response_payload,optional,omitempty"`
	RequestAt         string `json:"request_at,optional,omitempty"`
	ResponseAt        string `json:"response_at,optional,omitempty"`
	UpdatedAt         string `json:"updated_at,optional,omitempty"`
}

// 小手机消息输出结构（用于响应，null 字段不输出）
type PhoneMessageOutput {
	MessageId     string                     `json:"message_id,optional,omitempty"` // 消息ID（响应时返回，用于标识消息）
	RequestId     string                     `json:"request_id,optional,omitempty"` // AIGC 请求ID（viewer 追溯用）
	MsgType       string                     `json:"msg_type"` // 消息类型：'text'/'voice'/'image'/'gift'/'emoji'/'invitation'/'friend_request'/'friend_request_response'
	MsgDirection  string                     `json:"msg_direction,optional,omitempty"` // 消息方向：'user'（用户发送）/'character'（角色发送）/'system'（系统消息），响应时返回
	Emotion       string                     `json:"emotion,optional,omitempty"` // 消息级情绪（仅匿名聊天角色消息携带）：default/heartbeat/shy/emo
	IsFailed      bool                       `json:"is_failed,optional"` // 是否发送失败（true 表示发送失败，需要展示红色感叹号）
	Text          *PhoneMessageText          `json:"text,optional,omitempty"` // 文本消息内容（当 msg_type = 'text' 时使用；msg_type = 'friend_request' 时为角色邀请语）
	Voice         *PhoneMessageVoice         `json:"voice,optional,omitempty"` // 语音消息内容（当 msg_type = 'voice' 时使用）
	Image         *PhoneMessageImage         `json:"image,optional,omitempty"` // 图片消息内容（当 msg_type = 'image' 时使用）
	Emoji         *PhoneMessageEmoji         `json:"emoji,optional,omitempty"` // 表情消息内容（当 msg_type = 'emoji' 时使用）
	Gift          *PhoneMessageGift          `json:"gift,optional,omitempty"` // 礼物消息内容（当 msg_type = 'gift' 时使用）
	Invitation    *PhoneMessageInvitation    `json:"invitation,optional,omitempty"` // 邀约消息内容（当 msg_type = 'invitation' 时使用）
	HtmlFile      *PhoneMessageHtml          `json:"html_file,optional,omitempty"` // HTML文件消息内容（当 msg_type = 'html_file' 时使用）
	ChatForward   *PhoneMessageForward       `json:"chat_forward,optional,omitempty"` // 合并转发（当 msg_type = 'forward' 时使用）
	MediaForward  *PhoneMessageForward       `json:"media_forward,optional,omitempty"` // 合并转发（当 msg_type = 'forward' 时使用）
	FriendRequest *PhoneMessageFriendRequest `json:"friend_request,optional,omitempty"` // 好友请求
	IsRead        bool                       `json:"is_read,optional"` // 是否已读，true:已读 false:未读
	IsClick       bool                       `json:"is_click,optional"` // 是否已点击，true:已点击 false:未点击
	CreatedAt     int64                      `json:"created_at,optional,omitempty"` // 创建时间（Unix 时间戳，毫秒级）
	Cursor        string                     `json:"cursor,optional,omitempty"` // 消息游标（自增 id，字符串格式，如 "123"）
	LLM           *ViewerLLMTrace            `json:"llm,optional,omitempty"` // internal/viewer 关联到的 LLM 输入输出
}

type PhoneMessageFriendRequest {
	Prologues []string `json:"prologues"` // 开场白
}

// 角色基本信息（生成预览用）
type CharacterBasicInfo {
	Name             *string               `json:"name"` // 角色名称
	Aka              *string               `json:"aka"` // 角色称号
	Gender           *string               `json:"gender"` // 性别
	Species          *string               `json:"species,optional"` // 物种：人类/其他
	Profile          *string               `json:"profile"` // 性格描述
	Tag              []string              `json:"tag,optional"` // 标签数组，可选
	Voice            *CharacterVoice       `json:"voice,optional"` // 音色完整信息（与/character/list_character_voices返回的结构一致）
	IsPublic         *bool                 `json:"is_public"` // 是否公开
	RecognizeOthers  *bool                 `json:"recognize_others"` // 是否认识其他人
	PreMadeRelations []*CharacterRelation  `json:"pre_made_relations,optional"` // 大模型生成的预制关系
	CustomRelation   *CharacterRelation    `json:"custom_relation,optional"` // 用户填写的自制关系
	About            []*AboutCharacterInfo `json:"about,optional"` // 角色 about 信息（来源：AIGC /characters/generate 的 character_setting 叙事字段）
}

// 创建角色时用户填写的自制关系（简化结构，只用于创建接口）
type CreateCustomRelation {
	RelationName     string `json:"relation_name"` // 关系名，如情侣/朋友（必填）
	ImpressionToUser string `json:"impression_to_user,optional"` // 角色对用户的印象，如：温柔/坚强/其他（可选）
}

// 创建角色表单结构
type CharacterCreateForm {
	Images             []*UserUploadImage `json:"images,optional"`
	Name               *string            `json:"name,optional"`
	Tags               []string           `json:"tags,optional"`
	Species            *string            `json:"species,optional"`
	Gender             *string            `json:"gender,options=male|female|other,optional"`
	VoiceID            *string            `json:"voice_id,optional"` // 音色
	Profile            *string            `json:"profile,optional"` // 简介
	Disposition        *string            `json:"disposition,optional"` // 性格
	AnonymousTags      []string           `json:"anonymous_tags,optional"` // 匿名身份标签
	Visibility         *string            `json:"visibility,options=public|private,optional"` // 匿名身份标签
	CustomizedSettings map[string]string  `json:"customized_settings,optional"` // 匿名身份标签: map[content_key]value
	OpeningPrologue    []string           `json:"opening_prologue,optional"` // 开场白，一行一句话
	LandingPageURLs    []string           `json:"landing_page_urls,optional"`
}

type UserUploadImage {
	Name      string   `json:"name,optional"`
	ImageType string   `json:"image_type,options=aigc|upload"`
	Url       string   `json:"url"`
	IsMainPic bool     `json:"is_main_pic,optional"`
	Tags      []string `json:"tags,optional"`
}

type CharacterBasicInfoOutput {
	BasicInfo       CharacterBasicInfo `json:"basic_info"` // 角色基本信息
	BkgMainColor    *string            `json:"bkg_main_color,optional"` // 角色主色
	ImageShowObject *Media             `json:"image_show,optional"` // 形象, 展示用
}

// 肉体配置
type BodyConfig {
	SoulWordConfigs []SoulWordConfig      `json:"soul_word_configs"` // 灵魂词配置数组
	Gender          string                `json:"gender"` // 性别：男/女/其他 // 标记为废弃
	Species         string                `json:"species"` // 物种：人类/其他 // 标记为废弃
	CustomRelation  *CreateCustomRelation `json:"custom_relation,optional"` // 用户填写的自制关系（简化版，只需要传关系名和印象）// 标记为废弃
	StyleName       string                `json:"style_name"` // 画风：写实/可爱/其他 // 标记为废弃
	AnythingToAdd   string                `json:"anything_to_add,optional"` // 有什么要补充的
}

// 从灵魂配置生成角色请求
type GenCharacterFromSoulReq {
	BodyConfig BodyConfig `json:"body_config"` // 肉体配置
}

// 从灵魂配置生成角色响应
type GenCharacterFromSoulResp {
	Character    CharacterBasicInfoOutput `json:"character"` // 角色基本信息（包含关系信息）
	WalletStatus *WalletStatusInfo        `json:"wallet_status,omitempty"` // 扣费成功后的低余额软提醒；钱包未挂载/查询失败时省略
}

// 从输入生成外观请求
type GenAppearanceFromInputReq {
	CharacterID     *string              `json:"character_id,optional"`
	Draft           *CharacterCreateForm `json:"draft,optional"`
	UserPrompt      string               `json:"user_prompt,optional"` // 描述文本
	StyleKey        string               `json:"style_key,optional"` // 画风词
	ReferenceImages []string             `json:"reference_images,optional"`
	Scene           *string              `json:"scene,optional,options=create_character|update_appearance"` // 暂存场景，存储场景的定义
}

// 从输入生成外观响应
type GenAppearanceFromInputResp {
	Image          Media             `json:"image"` // 图片
	UserPrompt     *string           `json:"user_prompt"`
	ArtStylePrompt *string           `json:"art_style_prompt"`
	WalletStatus   *WalletStatusInfo `json:"wallet_status,omitempty"` // 扣费成功后的低余额软提醒；钱包未挂载/查询失败时省略
}

// 生成角色 Landing Page 请求
type GenLandingPageReq {
	CharacterId *string `json:"character_id,optional"` // 目标角色ID（可选，不传则直接按 user_prompt + style_key 生成并返回）
	UserPrompt  string  `json:"user_prompt"`
	StyleKey    *string `json:"style_key"`
}

// 生成角色 Landing Page 响应
type GenLandingPageResp {
	URL string `json:"url"` // AIGC 生成的 landing page URL
}

// 创建角色请求
type CreateCharacterReq {
	CharacterCreateForm CharacterCreateForm `json:"character_create_form"` // 角色基本信息
	Source              string              `json:"source,options=character|friend|system"` // character: 在角色创作页创建 friend: 添加好友页
}

// 创建角色响应
type CreateCharacterResp {
	CharacterId string `json:"character_id"` // 角色ID
}

// ======================= 创建角色 - 草稿箱 =======================
// 保存/更新创建角色草稿（upsert，不审核、不校验完整性）
type SaveCharacterDraftReq {
	DraftId             *string             `json:"draft_id,optional"` // 空=新建草稿；非空=更新指定草稿
	TargetCharacterId   *string             `json:"target_character_id,optional"` // 非空=编辑某已发布角色的草稿
	CharacterCreateForm CharacterCreateForm `json:"character_create_form"` // 表单快照，可任意残缺
}

type SaveCharacterDraftResp {
	DraftId   string `json:"draft_id"`
	UpdatedAt int64  `json:"updated_at"`
}

type ListCharacterDraftsReq {}

type GetCharacterDraftDetailReq {
	DraftId string `form:"draft_id"` // 草稿ID
}

type CharacterDraftItem {
	DraftId      string  `json:"draft_id"`
	Name         *string `json:"name,optional"`
	Cover        *Media  `json:"media,optional"`
	UpdatedAt    int64   `json:"updated_at"`
	Status       string  `json:"status"` // draft=编辑中 auditing=审核中 rejected=已拒绝
	RejectReason *string `json:"reject_reason,optional"` // 审核拒绝原因
}

// 草稿完整详情（含完整表单快照），供编辑回填
type CharacterDraftDetail {
	DraftId             string              `json:"draft_id"`
	TargetCharacterId   *string             `json:"target_character_id,optional"` // 非空=编辑某已发布角色
	CharacterCreateForm CharacterCreateForm `json:"character_create_form"` // 完整表单快照，可任意残缺
	UpdatedAt           int64               `json:"updated_at"`
	Status              string              `json:"status"` // draft=编辑中 auditing=审核中 rejected=已拒绝
	RejectReason        *string             `json:"reject_reason,optional"` // 审核拒绝原因
	CharacterId         *string             `json:"character_id,optional"` // 预分配(新建)/目标(编辑)角色ID
}

type GetCharacterDraftDetailResp {
	Draft *CharacterDraftDetail `json:"draft"`
}

type ListCharacterDraftsResp {
	Drafts []CharacterDraftItem `json:"drafts"`
}

type DeleteCharacterDraftReq {
	DraftId string `json:"draft_id"`
}

type DeleteCharacterDraftResp {}

type SubmitCharacterDraftReq {
	DraftId string `json:"draft_id"`
}

type SubmitCharacterDraftResp {
	CharacterId string `json:"character_id"`
}

// 基于草稿的调试聊天：用草稿人设直接聊一轮，用于调试角色（不创建角色 / 不扣费 / 单轮无记忆）
type DraftChatReq {
	DraftId  string              `json:"draft_id"`
	Messages []PhoneMessageInput `json:"messages"` // 本轮用户消息（复用聊天消息体）
}

type DraftChatResp {
	CharacterMessages []PhoneMessageOutput `json:"character_messages"` // 角色调试回复
}

// 查询异步任务状态请求
type GetTaskStatusReq {
	TaskId string `json:"task_id"` // 任务ID
}

type RetryAsyncTaskReq {
	TaskId string `json:"task_id"` // 要重试的失败任务ID
}

type RetryAsyncTaskResp {
	TaskId string `json:"task_id"` // 新任务ID
}

// 提交异步任务响应
type AsyncTaskSubmitResp {
	TaskId string `json:"task_id"` // 任务ID
}

// 查询异步任务状态响应
type GetTaskStatusResp {
	TaskId       string `json:"task_id"` // 任务ID
	TaskType     string `json:"task_type"` // 任务类型
	Status       string `json:"status"` // 任务状态：processing/ready/failed
	ShouldRetry  *bool  `json:"should_retry,optional,omitempty"` // 是否建议前端调用 /task/retry；部分任务类型（如 chat_with_character）不返回
	Result       string `json:"result,optional,omitempty"` // 任务成功后的原始响应 JSON 字符串
	ErrorMessage string `json:"error_message,optional,omitempty"` // 创建失败时的错误信息
	CreatedAt    int64  `json:"created_at"` // 创建时间戳（秒）
	UpdatedAt    int64  `json:"updated_at"` // 最近更新时间戳（秒）
	FinishedAt   int64  `json:"finished_at,optional,omitempty"` // 完成时间戳（秒）
}

// 角色列表查询请求
type ListCopyableCharactersReq {
	Keyword *string `json:"keyword,optional"` // 搜索关键词，可选
	Cursor  *string `json:"cursor,optional"` // 游标，可选，首次请求不传或传空
	Limit   int     `json:"limit,optional"` // 每页数量，可选，默认10
}

// 角色列表查询响应
type ListCopyableCharactersResp {
	Characters []CharacterListPageBasicInfo `json:"characters"` // 角色列表
	NextCursor string                       `json:"next_cursor"` // 下一个游标，如果没有更多数据则为空
	HasMore    bool                         `json:"has_more,optional"` // 是否还有更多数据
}

// 审核文本请求
type AuditTextReq {
	Text string `json:"text"` // 待审核的文本内容
}

// 审核文本响应
type AuditTextResp {
	IsPassed bool   `json:"is_passed"` // 是否通过审核
	Message  string `json:"message"` // 审核结果描述
}

// 用户自创角色列表请求
type ListUserCharactersReq {
	CurrentTime string `json:"current_time,optional"` // 当前时间，可选，格式为ISO8601或时间戳
	Cursor      string `json:"cursor,optional"` // 游标，可选，首次请求不传或传空
	Limit       int    `json:"limit,optional"` // 每页数量，可选，默认10
}

// 用户自创角色列表响应
type ListUserCharactersResp {
	Characters    []*CharacterPageBasicInfo `json:"characters"` // 角色列表
	MaxCharacters int                       `json:"max_characters"` // 最多可拥有的角色数量
	NextCursor    string                    `json:"next_cursor"` // 下一个游标，如果没有更多数据则为空
	HasMore       bool                      `json:"has_more,optional"` // 是否还有更多数据
}

// 聊天消息（保留用于向后兼容，建议使用 PhoneMessage）
type ChatMessage {
	MessageType string `json:"message_type"` // 消息类型：character/user
	Text        string `json:"text,optional"` // 文本内容
	EmojiId     string `json:"emoji_id,optional"` // 表情ID
	CreatedAt   int64  `json:"created_at"` // 创建时间（Unix 时间戳，毫秒级）
}

// 与角色聊天请求
type ChatWithCharacterReq {
	CharacterId  string `json:"character_id"` // 角色ID
	FriendshipID string `json:"friendship_id,optional"` // 好友关系ID，不带则开启非好友聊天模式，仅debug测试
	ChatScene    int32  `json:"chat_scene,options=1|2|3"` // 1: 小手机 2: 角色页面 3: 日程结束
	ScheduleId   string `json:"schedule_id,optional"` // 所属日程ID，可选
	// 当为重发红色感叹号消息时，传入需要重发的消息ID：
	// - 服务端查找该消息并重新调用 AI 生成回复
	// - 如果本次调用 AI 成功：插入新的「用户」「角色」正常消息，并删除原失败消息
	// - 如果本次调用 AI 仍失败：保留原失败消息不变
	ResendMessageId string              `json:"resend_message_id,optional"` // 重发的消息ID（可选，用于点击红点重发）
	Messages        []PhoneMessageInput `json:"messages"` // 用户发送的消息列表
}

// 与角色聊天响应
type ChatWithCharacterResp {
	CurrentMessages   []PhoneMessageOutput `json:"current_messages"` // 用户发送的消息列表（带 cursor id）
	CharacterMessages []PhoneMessageOutput `json:"character_messages"` // 角色回复的消息列表（可能有多条，每条都带 cursor id）
	CurrentStatus     CharacterStatus      `json:"character_status"` // 角色当前状态
	WalletStatus      *WalletStatusInfo    `json:"wallet_status,omitempty"` // 扣费成功后的低余额软提醒；钱包未挂载/查询失败时省略
}

// ==================== 转发帖子给角色 ====================
// 用户把一个 post 转发给好友角色：记录转发行为(msg_type=forward 消息) + 异步触发角色回复(免费)。
// 当前仅支持转发 post 给好友角色。
type ForwardPostToCharacterReq {
	CharacterId  string  `json:"character_id"` // 接收转发的角色（须为好友）
	PostId       string  `json:"post_id"` // 被转发的帖子
	ImpressionId *string `json:"impression_id,optional"` // feed/search 曝光id, 埋点用(可选)
}

type ForwardPostToCharacterResp {
	MessageId      string             `json:"message_id"` // 落库的转发消息 id
	ForwardMessage PhoneMessageOutput `json:"forward_message"` // 转发消息回显, 供前端乐观渲染（角色回复异步生成，前端轮询历史获取）
}

// 单个角色动作列表
type CharacterAppearance {
	AppearanceId   string `json:"appearance_id"` // 动作ID
	AppearanceName string `json:"appearance_name"` // EMTION或情感词
	IsDefault      bool   `json:"is_default"` // 是否默认
	InUse          bool   `json:"in_use"` // 是否在用
	Image          Media  `json:"image"` // 图片
}

// 单个角色皮肤详情
type CharacterOutfit {
	OutfitId     string                 `json:"outfit_id"` // 皮肤ID
	InUse        bool                   `json:"in_use"` // 是否在用
	IsDefault    bool                   `json:"is_default"` // 是否默认
	BkgMainColor *string                `json:"bkg_main_color,optional"` // 背景主色
	Appearances  []*CharacterAppearance `json:"appearances"` // 动作列表
}

type CharacterAbility {
	AbilityName  string `json:"ability_name"` // 能力名称
	AbilityValue int    `json:"ability_value"` // 能力值
	AbilityDesc  string `json:"ability_desc"` // 能力描述
	AbilityEmoji string `json:"ability_emoji"` // 能力表情
}

type CharacterSkill {
	SkillName  string `json:"skill_name"` // 技能名称
	SkillLevel string `json:"skill_level"` // 技能等级
}

type CharacterRelation {
	ToCharacterName  string `json:"to_character_name"` // 对方角色名字
	RelationName     string `json:"relation_name"` // 关系名，如情侣/朋友
	RelationDesc     string `json:"relation_desc,optional"` // 关系描述
	ImpressionToUser string `json:"impression_to_user,optional"` // 角色对用户的印象，如：温柔/坚强/其他（当to_character_name为"你"时使用）
}

// 角色详情信息
type CharacterDetailInfo {
	CharacterId         string                `json:"character_id"` // 角色全局ID
	SourceCharacterId   string                `json:"source_character_id"` // 父角色ID（被删除角色重新创建时用这个ID去copy）
	CreateSource        string                `json:"create_source,optional"` // 创建来源
	CreateSourceID      string                `json:"create_source_id,optional"` // 创建来源ID
	Name                string                `json:"name,optional"` // 角色名称
	Aka                 string                `json:"aka,optional"` // 角色称号
	Gender              string                `json:"gender,optional"` // 性别
	Species             string                `json:"species,optional"` // 物种
	Profile             string                `json:"profile,optional"` // 性格/经历描述
	Voice               *CharacterVoice       `json:"voice,optional"` // 用户选择的音色（单个）
	Outfits             []*CharacterOutfit    `json:"outfits,optional"` // 皮肤列表
	CurrentOutfitId     string                `json:"current_outfit_id,optional"` // 当前皮肤ID
	CurrentAppearanceId string                `json:"current_appearance_id,optional"` // 当前动作ID
	IsPublic            bool                  `json:"is_public,optional"` // 是否公开
	AbilitySum          int                   `json:"ability_sum"` // 能力值总和
	Skills              []*CharacterSkill     `json:"skills"` // 技能
	Abilities           []*CharacterAbility   `json:"abilities"` // 能力
	AbilityEvaluation   string                `json:"ability_evaluation"` //
	PreMadeRelations    []*CharacterRelation  `json:"pre_made_relations"` // 大模型生成的预制关系
	CustomRelation      *CharacterRelation    `json:"custom_relation,optional"` // 用户填写的自制关系（单个）
	SplashImg           *Media                `json:"splash_img,optional"`
	Album               []*Media              `json:"album,optional"` // 角色相册：创建时上传的全部图片（含主图），来自 user_resource_media(usage_type=character_album)
	LandingPageURLs     []string              `json:"landing_page_urls"`
	Author              *UserInfo             `json:"author,optional"` // 作者信息
	LikeCount           int64                 `json:"like_count"`
	IsLiked             bool                  `json:"is_liked,optional"` // 当前用户是否已点赞（reaction 表 target_type=1-character）
	OpeningLogPlayed    bool                  `json:"opening_log_played,optional"`
	About               []*AboutCharacterInfo `json:"about,optional"`
	CustomizedSettings  []GeneralTagInfo      `json:"customized_settings,optional"`
}

type AboutCharacterInfo {
	Title   string `json:"title,optional"`
	Content string `json:"content,optional"`
}

// 查看角色详情请求
type GetCharacterDetailReq {
	CharacterId  string `json:"character_id"` // 角色ID
	Source       string `json:"source,optional"` // 进入来源页枚举：feed / user_page / character_page / notification / direct
	ImpressionId string `json:"impression_id,optional"` // source=feed 时带上本次曝光的 impression_id，用于回流统计
}

// 落地页运行时数据接口契约（GET /character_landing_data）。
// 该接口由 arca 手动挂载 + 专用 HMAC 验签中间件实现（impl.CharacterLandingDataHandler，落地页 JS 调用、
// 非 App 客户端），故 service 块**不声明该路由**——否则 goctl 生成的 handler 会与手动路由重复注册导致启动 panic。
// 下列 Req/Resp 仍按 type 块正常生成到 types.go，仅作契约文档；运行时由手动 handler 内部同构 struct 返回。
// 响应为 {code, msg, data} 信封，data 即 GetCharacterLandingDataResp。
type GetCharacterLandingDataReq {
	CharacterId string `json:"character_id"` // 角色ID
	VersionNo   string `json:"version_no,optional"` // 版本号；省略时取最新版本
}

type LandingRelationship {
	Name       string `json:"name"` // 关系对象名
	Relation   string `json:"relation"` // 关系名称
	Impression string `json:"impression"` // 印象
}

type GetCharacterLandingDataResp {
	Name          string                 `json:"name"` // 角色名
	Aka           string                 `json:"aka"` // 称号
	Gender        string                 `json:"gender"` // 性别
	Species       string                 `json:"species"` // 物种
	Profile       string                 `json:"profile"` // 人设简介
	Personality   string                 `json:"personality"` // 性格
	Likes         string                 `json:"likes"` // 喜好
	Fears         string                 `json:"fears"` // 恐惧
	Backstory     string                 `json:"backstory"` // 背景故事
	LifeGoal      string                 `json:"life_goal"` // 人生目标
	KeyFeatures   string                 `json:"key_features"` // 关键特征
	CoverUrl      string                 `json:"cover_url"` // 封面图 URL（splash 优先、回退 avatar）
	AvatarUrl     string                 `json:"avatar_url"` // 头像 URL
	SplashUrl     string                 `json:"splash_url"` // 立绘大图 URL
	Relationships []*LandingRelationship `json:"relationships"` // 预制关系
}

// 查看角色详情响应
type GetCharacterDetailResp {
	Character CharacterDetailInfo `json:"character"` // 角色详情信息
}

