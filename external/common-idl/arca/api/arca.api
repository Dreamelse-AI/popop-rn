	NextCursor string `json:"next_cursor"`
}

type ReplayFromNarrativeReq {
	PlayId      string `json:"play_id"`
	NarrativeId string `json:"narrative_id"`
	UserMessage string `json:"user_message"` // 用户重玩的选项
}

type ReplayFromNarrativeResp {
	PlayId     string `json:"play_id"`
	NextCursor string `json:"next_cursor"`
}

type GetFeedTagsReq {}

type GeneralTagInfo {
	Index    *int32  `json:"index,omitempty"`
	TagKey   string  `json:"tag_key"`
	TagIcon  string  `json:"tag_icon"`
	TagName  string  `json:"tag_name"`
	TagValue *string `json:"tag_value,omitempty"`
}

type GetFeedTagsResp {
	Tags []*GeneralTagInfo `json:"tags"`
}

// 占位，还没有
type RecPostFilter {
	TagKey string `json:"tag_key"`
}

type GroupFilter {}

type CharacterFilter {
	Tag string `json:"tag"`
}

type ScriptFilter {
	Tag string `json:"tag"`
}

type RecAllPlayWithFilter {
	CharacterId    *string `json:"character_id,optional,omitempty"`
	GroupSessionId *string `json:"group_session_id,optional,omitempty"`
}

type RecAllReq {
	Source          *string               `json:"source,options=all|post|character|script|group|play_with,optional"` // 顶部tab 全部/动态/角色/故事/群聊/和Ta玩
	PostFilter      *RecPostFilter        `json:"post_filter,optional"`
	GroupFilter     *GroupFilter          `json:"group_filter,optional"`
	CharacterFilter *CharacterFilter      `json:"character_filter,optional"`
	ScriptFilter    *ScriptFilter         `json:"script_filter,optional"`
	PlayWithFilter  *RecAllPlayWithFilter `json:"play_with_filter,optional,omitempty"`
	RequestIndex    int32                 `json:"request_index"` // 同一个页面/条件下的请求次数，从1开始。
	ExcludeIds      []string              `json:"exclude_ids,optional"` // 曝光去重配置 // TODO 需要组合id
	Limit           *int                  `json:"limit,optional,omitempty"`
}

// 有图优先出图，无图出文本
type RecPostEntity {
	PostId         string   `json:"post_id"` // 帖子唯一id
	Title          string   `json:"title"` // 标题
	Images         []*Media `json:"images"` // 图片
	Body           string   `json:"body"` // 文本
	AuthorId       string   `json:"author_id"` // 发帖人的Id
	AuthorType     string   `json:"author_type,options=user|character"` // 发帖人/角色or用户
	AuthorName     string   `json:"author_name"` // 发帖人名
	AuthorPortrait *Media   `json:"author_portrait,optional"` // 发帖人的头像
	LikedCount     *int32   `json:"liked_count,optional"` // 点赞数
	IsLiked        bool     `json:"is_liked"` // 是否点赞
}

// TODO 不应该刷到自己的角色？或者不能复制自己的角色？
type RecCharacterEntity {
	CharacterId     string   `json:"character_id"` // 角色唯一id
	AppearanceMedia *Media   `json:"appearance_media,optional"` // 角色大图
	Name            string   `json:"name"` // 角色名
	Desc            string   `json:"desc"` // 描述
	Tags            []string `json:"tags"` // 左下角标签（中文原文，作内部 key 用，提交/查询用此值）
	TagsName        []string `json:"tags_name"` // 左下角标签的展示名（按 X-Language 翻译，仅用于前端展示，与 tags 一一对应）
	LikedCount      *int32   `json:"liked_count,optional"` // 点赞数
	IsLiked         bool     `json:"is_liked"` // 是否点赞
	RecType         string   `json:"rec_type"`
}

type RecGroupEntity {
	GroupTemplateId  string   `json:"group_template_id"` // 群模板Id
	GroupSessionId   *string  `json:"group_session_id,optional,omitempty"` // 群聊Id
	Title            string   `json:"title"` // 标题
	CoverMemberCount int      `json:"cover_member_count"` // 封面成员人数
	AppearanceMedias []*Media `json:"appearance_medias,optional"`
	Tags             []string `json:"tags"` // 左下角标签（中文原文，作内部 key 用）
	TagsName         []string `json:"tags_name"` // 左下角标签的展示名（按 X-Language 翻译，与 tags 一一对应）
	LikedCount       *int32   `json:"liked_count,optional"` // 点赞数
	IsLiked          bool     `json:"is_liked"` // 是否点赞
}

// ========================== feed/rec_popop（海外专用混合 feed） ==========================
// 海外 feed 流
type RecPromoEntity {
	PromoId     string `json:"promo_id"` // 运营位 id，用于曝光/点击上报
	HtmlContent string `json:"html_content"` // 渲染用 HTML 片段；前端在 WebView/iframe 容器内渲染
	CoverUrl    string `json:"cover_url,optional"` // 封面图 URL（https://... 或 data:image/...;base64,...），前端预览展示用
	Height      *int32 `json:"height,optional"` // 固定高度（px），前端预占位避免抖动；空则按内容自适应
	JumpUrl     string `json:"jump_url,optional"` // 整块点击兜底跳转（HTML 内部已有锚点时可为空）
	BgColor     string `json:"bg_color,optional"` // 背景色（loading 占位用，hex like #FFFFFF）
}

type RecPopopEntity {
	ImpressionId       string              `json:"impression_id"` // 曝光 id，配合 /feed/item_report 上报
	EntityType         string              `json:"entity_type,options=post|character|promo"` // 实体类型
	RecPostEntity      *RecPostEntity      `json:"rec_post_entity,optional,omitempty"` // 帖子
	RecCharacterEntity *RecCharacterEntity `json:"rec_character_entity,optional,omitempty"` // 角色
	RecPromoEntity     *RecPromoEntity     `json:"rec_html_promo_entity,optional,omitempty"` // html 运营位
	ContentRegion      string              `json:"content_region"`
	ContentLanguage    *string             `json:"content_language,omitempty"`
}

type FeedRecPopopReq {
	Source          *string          `json:"source,options=all|post|character,optional"` // 顶部tab 全部/动态/角色/故事/群聊/和Ta玩
	PostFilter      *RecPostFilter   `json:"post_filter,optional"`
	CharacterFilter *CharacterFilter `json:"character_filter,optional"`
	RequestIndex    int32            `json:"request_index"` // 同一页面/条件下的请求次数，从 1 开始
	ExcludeIds      []string         `json:"exclude_ids,optional"` // 曝光去重：组合 id（envelope 维度，如 post:xxx / character_group:yyy / html:zzz）
	Limit           *int             `json:"limit,optional,omitempty"` // 每页条目数，默认 10
}

type FeedRecPopopResp {
	Entities []*RecPopopEntity `json:"entities"`
}

type RecAllEntity {
	ImpressionId       string              `json:"impression_id"` // 曝光id
	EntityType         string              `json:"entity_type,options=post|character|script|group"` // 实体类型
	RecPostEntity      *RecPostEntity      `json:"rec_post_entity,optional,omitempty"` // 帖子
	RecCharacterEntity *RecCharacterEntity `json:"rec_character_entity,optional,omitempty"` // 角色
}

type RecAllResp {
	Entities []*RecAllEntity `json:"entities"`
}

type ItemReportEntity {
	ImpressionId string `json:"impression_id"`
	EntityType   string `json:"entity_type,options=post|character|promo"` // 实体类型
	EntityId     string `json:"entity_id"` // 与 entity_type 对应的业务实体 id
}

