}

type FeedItemReportResp {}

type FeedRecallCharactersReq {
	RequestId         *string `json:"request_id,optional"`
	Strategy          string  `json:"strategy,options=hot|interaction"` // 召回策略
	InteractionPostId *string `json:"interaction_post_id,optional"` // 互动召回中，互动的帖子Id
	Limit             *int    `json:"limit,optional,omitempty"` // 每页条目数，默认 5
}

type FeedRecallCharactersResp {
	Entities []*RecPopopEntity `json:"entities"`
