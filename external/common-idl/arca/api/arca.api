// 获得聊天历史
type ListCharacterPhoneChatHistoryReq {
	CharacterId string `json:"character_id"` // 角色ID
	// ===== 分页参数（与仓库整体风格一致，使用自增 id 作为 cursor）=====
	Cursor    string `json:"cursor,optional"` // 消息游标（自增 id，字符串格式，如 "123"）
	Direction string `json:"direction,optional,options=up|down"` // up: 向更旧拉取；down: 向更新拉取；不传默认 up（有 cursor 时）
	OrderBy   string `json:"order_by,optional,options=desc|asc"` // 排序：desc/asc；不传默认 asc（正序，早的在前面）
	Limit     int32  `json:"limit,optional"` // 限制返回数量，默认10，最大100
	// ===== 兼容旧参数（不推荐）=====
	LastMessageId string `json:"last_message_id,optional"` // 旧游标字段（message_id），已废弃，建议使用 cursor
	StartTime     string `json:"start_time,optional"` // 起始时间（RFC3339格式），可选
	EndTime       string `json:"end_time,optional"` // 结束时间（RFC3339格式），可选
}

type ListCharacterPhoneChatHistoryResp {
	Msgs        []*PhoneMessageOutput `json:"msgs"` // 历史消息（完整的消息结构，包含所有消息类型，null 字段不输出）
	MinCursor   string                `json:"min_cursor"` // 本次返回的最小游标（自增 id，字符串格式），用于向上翻页
	MaxCursor   string                `json:"max_cursor"` // 本次返回的最大游标（自增 id，字符串格式），用于向下翻页
	UpHasMore   bool                  `json:"up_has_more"` // min_cursor 之前是否还有数据
	DownHasMore bool                  `json:"down_has_more"` // max_cursor 之后是否还有数据
}

type NarrativeCompositionSubject {
	Role        string   `json:"role"`
	Appearance  string   `json:"appearance"`
	RoleType    string   `json:"role_type,optional"`
	EffectNames []string `json:"effect_names,optional"`
}

// 登录 / 注册模块（auth）。
service arca_api {
	// [DEPRECATED 2026-05-28] 手机号验证码登录/注册已废弃，注释保留以备恢复。
	@handler sendCode
	post /auth/send_code (SendCodeReq) returns (SendCodeResp)

	@handler verifyCode
	post /auth/verify_code (VerifyCodeReq) returns (VerifyCodeResp)

	@handler appLoginRedirect
	post /auth/app_login_redirect (AppLoginRedirectRequest) returns (AppLoginRedirectResponse)

	// 三方 + Apple 登录（OIDC 统一）：provider ∈ {google, line, kakao, apple}
	@handler oauthLogin
	post /auth/oauth/:provider/sessions (OAuthSessionReq) returns (LoginResp)

	// 邮箱验证码登录：发码 + 验码登录（自建 Redis 存储/限流，163 SMTP 发信）
	@handler sendEmailCode
	post /auth/email/verification-codes (EmailCodeReq) returns (EmailCodeResp)

	@handler emailLogin
	post /auth/email/sessions (EmailSessionReq) returns (LoginResp)
}

info (
	// for swagger
	securityDefinitionsFromJson: `{"apiKey":{"type":"apiKey","name":"Authorization","in":"header"},"petstore_auth":{"type":"oauth2","authorizationUrl":"http://swagger.io/api/oauth/dialog","flow":"implicit","scopes":{"write:pets":"modify pets in your account","read:pets":"read your pets"}}}`
	schemes:                     "http" // 支持协议(http/https/ws/wss)，可配置多个
)

// 不鉴权，不开放外网访问
@server (
	tags: "（无鉴权）内部接口-平台侧"
)
service arca_api {
	// 属性表
	// 获取属性与属性值
	// 新增属性
	// 新增属性的属性值
	// 修改属性值
	// 获得某个实体的属性-属性值表
	// 为某个实体新增属性-属性值
	// 删除属性-属性值
	// ==================== 画风配置运营接口 ====================
	// 列出当前画风词信息（按优先级）
	@handler listStylePrompt
	post /internal/ops/style_prompt/list returns (ListStylePromptResp)

	// 新增画风词
	@handler createStylePrompt
	post /internal/ops/style_prompt/create (CreateStylePromptReq) returns (CreateStylePromptResp)

	// 修改单条画风词的信息（优先级，词名）
	@handler updateStylePrompt
	post /internal/ops/style_prompt/update (UpdateStylePromptReq) returns (UpdateStylePromptResp)

	// 删除画风词
