}

type FeedPopopSearchReq {
	Type    *string `json:"type,optional,options=character|post"`
	Keyword *string `json:"keyword,optional,omitempty"`
	Limit   *int32  `json:"limit,optional,omitempty"`
	Cursor  *string `json:"cursor,optional,omitempty"`
}

type FeedPopopSearchResp {
	Entities   []*RecPopopEntity `json:"entities"`
	NextCursor string            `json:"next_cursor"`
}

// 可选鉴权，兼容游客态
@server (
	tags:    "兼容游客态的API，可选鉴权"
	timeout: 60s
)
service arca_api {
	// 拉取tag
	@handler getFeedTags
	get /feed/tags returns (GetFeedTagsResp)

	// 海外混合 feed（post / character_group / html）
	@handler recPopop
	post /feed/rec_popop (FeedRecPopopReq) returns (FeedRecPopopResp)

	// popop feed/搜索/上报接口
	@handler feedRecommendation
	post /feed/recommendation (FeedRecommendationReq) returns (FeedRecommendationResp)

	// 上报feed/搜索的物品曝光/点击/其他互动事件
	@handler feedItemReport
	post /feed/item_report (FeedItemReportReq) returns (FeedItemReportResp)

	// feed页Carousel轮播角色召回，分策略
	@handler feedRecallCharacters
	post /feed/recall_characters (FeedRecallCharactersReq) returns (FeedRecallCharactersResp)

	// feed页Carousel轮播角色召回，全部
	@handler feedMoreCharacters
	post /feed/more_characters (FeedMoreCharactersReq) returns (FeedMoreCharactersResp)

	// 首页搜索
	@handler feedPopopSearch
	post /feed/popop_search (FeedPopopSearchReq) returns (FeedPopopSearchResp)
}

