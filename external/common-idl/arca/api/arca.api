// APP端feed/搜索
@server (
	jwt:      Auth // 开启 jwt 认证
	authType: apiKey
	tags:     "主端Feed与搜索模块"
	timeout:  60s
)
service arca_api {
	// 搜索hint
	@handler getSearchHint
	post /feed/get_search_hint (GetSearchHintReq) returns (GetSearchHintResp)

	// 收藏剧本
	@handler favouriteScript
	post /feed/favourite_script (FavouriteScriptReq) returns (FavouriteScriptResp)

	// 取消收藏剧本
	@handler unfavouriteScript
	post /feed/unfavourite_script (UnfavouriteScriptReq) returns (UnfavouriteScriptResp)

	// 列出和他玩可选的角色
	@handler listPlayWithCharacters
	post /feed/list_play_with_characters (ListPlayWithCharactersReq) returns (ListPlayWithCharactersResp)
}

type PrefetchReqEntity {
	ScriptId     string  `json:"script_id"`
	Version      string  `json:"version"`
	ActivePlayId *string `json:"active_play_id,optional,omitempty"`
}

type PrefetchResourcesReq {
	Lists []*PrefetchReqEntity `json:"lists"`
}

type PrefetchRespEntity {
	ScriptId         string   `json:"script_id"`
	Version          string   `json:"version"`
	ActivePlayId     *string  `json:"active_play_id,optional,omitempty"`
	BackgroundMedias []*Media `json:"background_medias"` // 背景资源
	MusicMedias      []*Media `json:"music_medias"` // 音乐资源
	LayoutMedias     []*Media `json:"layout_medias"` // 布局图资源
	AmbientMedias    []*Media `json:"ambient_medias"` // 环境音
	VoiceFXMedias    []*Media `json:"voice_fx_medias"` // 音效资源
	EffectMedias     []*Media `json:"effect_medias"` // 特效资源
	TTSMedias        []*Media `json:"tts_medias"` // 语音资源
	AppearanceMedias []*Media `json:"appearance_medias"` // 角色形象资源
}

type PrefetchResourcesResp {
	Lists []*PrefetchRespEntity `json:"lists"`
}

type SetPGCBackgroundReq {
	ScriptId string  `json:"script_id"`
	Version  *string `json:"version,optional,omitempty"` // 如不传，则更新最大版本
	TosLink  string  `json:"tos_link"`
}

type SetPGCBackgroundResp {}

type FeedRecommendationReq {
	PostFilter   *RecPostFilter `json:"post_filter,optional"`
	RequestId    *string        `json:"request_id,optional"`
	RequestIndex int32          `json:"request_index"` // 同一页面/条件下的请求次数，从 1 开始
	ExcludeIds   []string       `json:"exclude_ids,optional"` // 曝光去重：组合 id（envelope 维度，如 post:xxx / character_group:yyy / html:zzz）
	Limit        *int           `json:"limit,optional,omitempty"` // 每页条目数，默认 10
}

type FeedRecommendationResp {
	Entities []*RecPopopEntity `json:"entities"`
}

