type GetImageMainColorReq {
	Image *TOSObject `json:"image"`
}

type GetImageMainColorResp {
	BkgMainColor string `json:"bkg_main_color"`
}

type ProcessImageReq {
	ImageUrl string `json:"image_url"` // 原始图片 URL 公网链接
}

type ProcessImageResp {
	ImageUrl string `json:"image_url"` // 处理后的图片 URL
}

@server (
	jwt:      Auth // 开启 jwt 认证
	authType: apiKey
	tags:     "通用模块（鉴权）"
)
service arca_api {
	//============ 文件上传模块 =============
	@handler getTosUploadCredential
	post /file/tos_credential (GetTosUploadCredentialReq) returns (GetTosUploadCredentialResp)

	//=========== 算色接口 =================
	@handler getImageMainColor
	post /file/image_main_color (GetImageMainColorReq) returns (GetImageMainColorResp)

	//=========== 图片抠图处理 =================
	@handler processImage
	post /file/process_image (ProcessImageReq) returns (AsyncTaskSubmitResp)

	//=========== 异步任务状态查询 =================
	@handler getTaskStatus
	post /task/get_status (GetTaskStatusReq) returns (GetTaskStatusResp)

	@handler retryAsyncTask
	post /task/retry (RetryAsyncTaskReq) returns (RetryAsyncTaskResp)

	//============ 同步调用的安审模块 =============
	// 文本审核
	@handler auditText
	post /audit/text (AuditTextReq) returns (AuditTextResp)

	@handler auditImage
	post /audit/image (AuditImageReq) returns (AuditImageResp)

	// ========== 条款 ===================
	// 记录用户同意条款（幂等，重复同意不报错且保留首次同意时间）
	@handler agreeTerms
	post /app/agree_terms (AgreeTermsReq) returns (AgreeTermsResp)
}

type ReportAppLogReq {
	JsonData string `json:"json_data"`
}

type ReportAppLogResp {}

type TermsInfo {
	TermsId  string `json:"terms_id"` // 条款唯一标识，同意后透传给 /app/agree_terms
	Type     string `json:"type"` // 条款类型：user_agreement / privacy_policy / marketing 等
	Title    string `json:"title"` // 条款展示文案（按条款适用地区的语言配置，如 KR 为韩文）
	Version  string `json:"version"` // 条款版本号
	Link     string `json:"link"` // 条款内容链接
	Required bool   `json:"required"` // 是否必须同意才能使用
}

type AppTermsResp {
	UserAgreementLink string      `json:"user_agreement"` // 【兼容字段】用户协议链接，新前端请使用 terms_list
	PrivacyPolicyLink string      `json:"privacy_policy"` // 【兼容字段】隐私政策链接，新前端请使用 terms_list
	XHSLink           string      `json:"xhs"`
	TermsList         []TermsInfo `json:"terms_list"` // 按用户地区匹配出的条款列表
}

type AgreedTermsItem {
	TermsId      string `json:"terms_id"` // 条款唯一标识（透传 get_terms 返回值）
	TermsVersion string `json:"terms_version,optional"` // 同意的条款版本（透传 get_terms 返回值）；为空时服务端取该条款当前配置版本
}

type AgreeTermsReq {
	TermsList []AgreedTermsItem `json:"terms_list"` // 本次同意的条款列表，不可为空
}

type AgreeTermsResp {}

type AppConfigResp {
	AllowRecordScreen bool `json:"allow_record_screen"`
}

type GetIPRegionResp {
	Region string `json:"region"` // ISO 3166-1 alpha-2 大写国家/地区码（如 "US"）；无法解析时为空字符串
}

@server (
	tags: "通用模块（不鉴权）"
)
service arca_api {
	// =========== 日志 =================
	@handler reportAppLog
	post /report/app_log (ReportAppLogReq) returns (ReportAppLogResp)

	// ========== 条款 ===================
	// 返回按用户地区匹配的条款列表（region 不传时按请求 IP 解析；空 body 兼容旧客户端）
	@handler getTerms
	get /app/terms returns (AppTermsResp)

	// ======= 配置 =========
	@handler getAppConfig
	post /app/config returns (AppConfigResp)

	// 上报 App 前后台状态（可作为前台心跳）
	@handler reportAppState
	post /app/report_app_state (ReportAppStateReq) returns (ReportAppStateResp)

	// ======= IP 地区 =========
	// 服务端按来源 IP 解析地区码：优先 CDN/网关地理头，兜底本地 GeoIP 库
	@handler getIPRegion
	get /app/ip_region returns (GetIPRegionResp)
}

type GetGenerationTemporaryAssetReq {
	Scene        string  `json:"scene,optional,options=create_appearance|create_character|create_outfit|update_appearance"` // 暂存场景，存储场景的定义
	CharacterId  *string `json:"character_id,optional"`
	OutfitId     *string `json:"outfit_id,optional"`
	AppearanceId *string `json:"appearance_id,optional"`
}

type GenerationTemporaryAsset {
	AssetId string `json:"asset_id"`
	Media   Media  `json:"media"`
}

type GetGenerationTemporaryAssetResp {
	Assets []*GenerationTemporaryAsset `json:"assets,optional"` // 暂存的media资产
}

type DelGenerationTemporaryAssetReq {
	AssetIds []string `json:"asset_ids"`
}

type DelGenerationTemporaryAssetResp {}

// Todo角色页装扮商城那块完全没有定义
@server (
	jwt:      Auth // 开启 jwt 认证
	authType: apiKey
	tags:     "角色模块"
	timeout:  300s
)
service arca_api {
	//============ 用户角色模块 =============
	// ======================= 创建角色 - 调配 =======================
	@handler getBodyConfig
	post /character/body_config returns (BodyConfigResp)

	// ======================= 创建角色 - 挑选 =======================
	// 搜索可复制的角色 // TODO 官方排序规则定义一下
	@handler listCopyableCharacters
	post /character/list_copyable_characters (ListCopyableCharactersReq) returns (ListCopyableCharactersResp)

	// e.g. 搜索后，查看角色详情（可查看自己或公开角色）
	@handler getCharacterDetail
	get /character/detail (GetCharacterDetailReq) returns (GetCharacterDetailResp)

	// 注：/character_landing_data 由 arca 手动挂载 + 专用 HMAC 验签中间件实现
	// （impl.CharacterLandingDataHandler，见 arca.go），不在此声明路由——避免 goctl 生成的
	// handler 与手动路由重复注册导致启动 panic。契约类型见上方 GetCharacterLandingDataReq/Resp。
	// [POPOP] 获取角色创建表单配置（性别、身份等枚举值）
	@handler getCharacterPageConfig
	get /character/page_config returns (GetCharacterPageConfigResp)

	// 从用户输入生成皮肤 // 有计数/付费需求
	@handler genAppearanceFromInput
	post /character/gen_appearance (GenAppearanceFromInputReq) returns (AsyncTaskSubmitResp)

	// [POPOP] 生成角色 landing page（直接同步调用 AIGC，AIGC 侧 schema 待对接）
	@handler genLandingPage
	post /character/gen_landing_page (GenLandingPageReq) returns (GenLandingPageResp)

	// [POPOP] 创建角色（异步：返回 task_id，结果通过 /task/get_status 轮询，result 为 CreateCharacterResp JSON）
	@handler createCharacter
	post /character/create (CreateCharacterReq) returns (AsyncTaskSubmitResp)

	// [POPOP] 保存/更新创建角色草稿（不审核、不校验完整性）
	@handler saveCharacterDraft
	post /character/save_draft (SaveCharacterDraftReq) returns (SaveCharacterDraftResp)

	// [POPOP] 我的创建角色草稿列表
	@handler listCharacterDrafts
	post /character/list_drafts (ListCharacterDraftsReq) returns (ListCharacterDraftsResp)

	// [POPOP] 创建角色草稿详情（完整表单，供编辑回填）
	@handler getCharacterDraftDetail
	get /character/draft_detail (GetCharacterDraftDetailReq) returns (GetCharacterDraftDetailResp)

	// [POPOP] 删除创建角色草稿
	@handler deleteCharacterDraft
	post /character/delete_draft (DeleteCharacterDraftReq) returns (DeleteCharacterDraftResp)

	// [POPOP] 提交草稿转正（新建或覆盖已发布角色）。异步审核：立即返回 character_id（新建为预分配 id，
	// 审核通过前角色不可查），草稿置 auditing；审核通过才实际发布，拒绝则草稿带 reject_reason 可重提
	@handler submitCharacterDraft
	post /character/submit_draft (SubmitCharacterDraftReq) returns (SubmitCharacterDraftResp)

	// [POPOP] 基于草稿调试聊天（用草稿人设直接聊；不创建角色 / 不扣费 / 单轮无记忆）
	@handler draftChat
	post /character/draft_chat (DraftChatReq) returns (DraftChatResp)

	// ======================= 角色 - Ta世界 =======================
	// 查询：用户自创角色查看页面（Ta的世界）+ 最多可拥有角色数量
	@handler listUserCharacters
	post /character/list_my_characters (ListUserCharactersReq) returns (ListUserCharactersResp)

	// 置顶角色
	@handler pinCharacter
	post /character/pin (PinCharacterReq) returns (PinCharacterResp)

	// 取消置顶角色
	@handler unpinCharacter
	post /character/unpin (UnpinCharacterReq) returns (UnpinCharacterResp)

	// 获得聊天历史
	@handler list_character_phone_chat_history
	post /character/list_phone_chat_history (ListCharacterPhoneChatHistoryReq) returns (ListCharacterPhoneChatHistoryResp)

	// TODO 购买解锁新的角色槽位，调用过程是怎么样的？
	// Post: 在小手机页面，在角色主页或日程结束后，跟单个角色聊天接口
	@handler syncChatWithCharacter
	post /character/chat_with_character (ChatWithCharacterReq) returns (ChatWithCharacterResp)

	@handler chatWithCharacter
	post /character/chat (ChatWithCharacterReq) returns (ChatWithCharacterResp)

	// 转发帖子给好友角色：记录转发行为 + 异步触发角色回复（免费）。前端轮询 /character/list_phone_chat_history 获取回复
	@handler forwardPostToCharacter
	post /character/forward_post (ForwardPostToCharacterReq) returns (ForwardPostToCharacterResp)

	// ====================== 角色 - 角色日程 ========================
	// 拉取角色日程 输入当前时间 返回当天的全部日程
	@handler listCharacterScheduleByDay
	post /character/list_schedule_by_day (listCharacterScheduleByDayReq) returns (listCharacterScheduleByDayResp)

	// 生成角色日程
	@handler generateCharacterSchedule
	post /character/generate_schedule (GenerateCharacterScheduleReq) returns (GenerateCharacterScheduleResp)

	// 批量更新日程已读未读状态
	@handler updateScheduleViewedStatus
	post /character/update_schedule_viewed_status (UpdateScheduleViewedStatusReq) returns (UpdateScheduleViewedStatusResp)

	// 标记消息已读状态（仅对文字、图片、表情消息生效）
	@handler updateMessageReadStatus
	post /character/update_message_read_status (UpdateMessageReadStatusReq) returns (UpdateMessageReadStatusResp)

	// 清除角色和群聊会话的 is_new 标记
	@handler updateIsNewStatus
	post /character/update_is_new_status (UpdateIsNewStatusReq) returns (UpdateIsNewStatusResp)

	// 标记消息已点击状态（仅对语音、礼物、邀约消息生效）
	@handler updateMessageClickStatus
	post /character/update_message_click_status (UpdateMessageClickStatusReq) returns (UpdateMessageClickStatusResp)

	// 记忆回滚 - 软删除指定消息之后的聊天记录并回滚AI记忆
	@handler memoryRollback
	post /character/memory_rollback (MemoryRollbackReq) returns (MemoryRollbackResp)

	// 获取角色回忆摘要（opening_log / 该角色参与过的剧本 / 该角色发起的邀约）
	@handler getCharacterMemories
	post /character/get_memories (GetCharacterMemoriesReq) returns (GetCharacterGroupMemoriesResp)

	// 获取回忆详情（点击回忆卡片后拉取 narratives）
	@handler getMemoryNarratives
	post /memory/get_narratives (GetMemoryNarrativesReq) returns (GetMemoryNarrativesResp)

	// 删除回忆实体（只影响回忆展示，不影响来源对象）
	@handler deleteMemory
	post /memory/delete (DeleteMemoryReq) returns (DeleteMemoryResp)

	// TODO 购买日程
	// TODO 角色日程撤销的重新生成的时机和怎么调用
	// ====================== 角色详情页 - 编辑角色 ================================
	// 修改角色基本信息 名称 aka 公开 是否认识 TODO: 全量更新？
	@handler updateCharacterBasicInfo
	post /character/updateBasicInfo (UpdateCharacterBasicInfoReq) returns (UpdateCharacterBasicInfoResp)

	// 删除角色（软删除，编辑端/我的角色不可见，但保留给存量剧本使用）
	@handler deleteCharacter
	post /character/delete (DeleteCharacterReq) returns (DeleteCharacterResp)

	// 新建：新建皮肤
	@handler createCharacterAppearance
	post /character/create_appearance (CreateAppearanceReq) returns (CreateAppearanceResp)

	// 更新：修改某个皮肤
	@handler updateCharacterAppearance
	post /character/update_appearance (UpdateAppearanceReq) returns (UpdateAppearanceResp)

	// 切换角色皮肤
	@handler switchCharacterOutfit
	post /character/switch_outfit (SwitchOutfitReq) returns (SwitchOutfitResp)

	// 获取单个角色的所有外观，公开的或自己的
	@handler listCharacterAppearances
	post /character/list_appearances (ListCharacterAppearancesReq) returns (ListCharacterAppearancesResp)

	// 查询灵魂词评论
	@handler getSoulWordEvaluation
	post /character/get_soul_word_evaluation (GetSoulWordEvaluationReq) returns (GetSoulWordEvaluationResp)
// ==================== 装扮商城 ===========================================
// TODO 还没定义
}

// 剧本创作用户输入的实体 - 全部字段
type ScriptInputEntity {
	Title               string   `json:"title"` // 剧本标题，必填
	RoleArrangementType int32    `json:"role_arrangement_type,options=1|2"` // 1:我来安排 2:用户安排
	Story               string   `json:"story"` // 剧本正文，必填
	StoryTypes          []string `json:"story_types"` // 多个标签，逗号拼接
	// Ending              string        `json:"ending,optional"` // 结局，选填
	OpeningStory    string        `json:"opening_story,optional"` // 开场剧情设计
	StoryFlow       []string      `json:"story_flow,optional"` // 剧情走向示意
	FixedRoles      []*ScriptRole `json:"fixed_roles,optional"` // 固定的角色槽位
	TBDRoles        []*ScriptRole `json:"tbd_roles,optional"` // 开放的角色槽位
	NPCRoles        []*ScriptRole `json:"npc_roles,optional"` // NPC角色槽位
	ScriptSceneTags []string      `json:"script_scene_tags,optional"` // 剧本场景标签，对应 script_version.script_scene_tags
}

type CharacterShowInfo {
	CharacterId    string    `json:"character_id"` // 角色ID
	OutfitId       string    `json:"outfit_id,optional"` // 选择的皮肤ID
	IsOwner        bool      `json:"is_owner,optional"` // 当前用户是否本角色的拥有者
	CreateSource   string    `json:"create_source,options=character|script|friend_request"` // 用户创建的路径路径
	CreateSourceID string    `json:"create_source_id,optional"` // 用户创建的路径路径的来源ID
	Name           string    `json:"name,optional"` // 角色名称
	Aka            string    `json:"aka,optional"` // 别名/昵称，选填
	Image          Media     `json:"image,optional"` // 形象
	BkgMainColor   *string   `json:"bkg_main_color,optional"`
	Author         *UserInfo `json:"author,optional"` // 作者信息，这里只要user_id
}

// 角色槽位 - 演员绑定
type ScriptRole {
	Identites       []string           `json:"identities"` // 身份
	Background      *string            `json:"background,optional"` // 角色故事，选填
	ExtraBackground *string            `json:"extra_background,optional"` // 额外背景，用户自定义
	Goal            *string            `json:"goal,optional"` // 角色目标
	Secret          *string            `json:"secret,optional"` // 角色目标，选填
	CharacterInfo   *CharacterShowInfo `json:"character_info,optional"` // 槽位绑定的演员信息
	RoleId          *string            `json:"role_id,optional"` // 槽位的id
}

type CreateScriptReq {
	ScriptInfo ScriptInputEntity `json:"script_info"` // 剧本输入全部信息
}

type CreateScriptResp {
	ScriptId string `json:"script_id"` // 返回剧本id
	Version  string `json:"version"` // 返回剧本版本号
}

type UpdateScriptReq {
	ScriptId   string            `json:"script_id"` // 剧本ID，必填
	Version    string            `json:"version"` // 编辑的版本
	ScriptInfo ScriptInputEntity `json:"script_info"` // 剧本输入全部信息
// title,  story必填；角色槽位数组，ending，开场剧情设计, NPC角色，剧情走向示意可选
}

type UpdateScriptResp {
	ScriptId string `json:"script_id"` // 剧本ID
	Version  string `json:"version"` // 剧本当前版本号
}

type PublishScriptReq {
	ScriptId string `json:"script_id"` // 剧本ID
	Version  string `json:"version"` // 发布的版本
}

type PublishScriptResp {
	ScriptId string `json:"script_id"` // 剧本ID
	Version  string `json:"version"` // 剧本发布后版本号
}

type ListSelectableCharacterRoleFilter {
	RoleIdentity *string  `json:"role_identity,optional"` //
	ScriptTypes  []string `json:"script_types"` // 剧本类别
}

type ListSelectableCharacterReq {
	Query      *string                            `json:"query,optional"`
	RoleFilter *ListSelectableCharacterRoleFilter `json:"role_filter,optional"` // 默认搜索下，给出的条件
	Cursor     string                             `json:"cursor,optional"` // 游标，可选，首次请求不传或传空
	Limit      int                                `json:"limit,optional"` // 每页数量，可选，默认20
}

type ListSelectableCharacterResp {
	Lists      []*CharacterShowInfo `json:"lists"`
	NextCursor string               `json:"next_cursor"` // 下一个游标，如果没有更多数据则为空
	HasMore    bool                 `json:"has_more,optional"` // 是否还有更多数据
}

type ScriptRoleCharacterBind {
	RoleId      string `json:"role_id"`
	CharacterId string `json:"character_id"`
}

type ReportPlayedNarrativeIdReq {
