	Keys []string `json:"keys,optional"` // 可选：按 key/name 过滤，不传则返回全部
}

// 素材项
type ViewerMaterialItem {
	MaterialId string                 `json:"material_id"` // 素材ID
	Key        string                 `json:"key,optional"` // 素材Key
	Name       string                 `json:"name"` // 素材名称
	Type       string                 `json:"type"` // 素材类型
	ResourceId string                 `json:"resource_id,optional"` // 资源ID
	Url        string                 `json:"url,optional"` // 资源URL
	Width      int                    `json:"width,optional"` // 宽度
	Height     int                    `json:"height,optional"` // 高度
	Duration   int                    `json:"duration,optional"` // 时长(毫秒)
	Extra      map[string]interface{} `json:"extra,optional"` // 扩展字段
}

// 素材列表响应
type ListViewerMaterialsResp {
	Materials []*ViewerMaterialItem `json:"materials"` // 素材列表
}

// 角色外观信息
type ViewerAppearanceItem {
	AppearanceId   string `json:"appearance_id"` // 外观ID
	AppearanceName string `json:"appearance_name"` // 外观名称(情绪词)
	IsDefault      bool   `json:"is_default"` // 是否默认
	ImageUrl       string `json:"image_url,optional"` // 图片URL
	ImageWidth     int    `json:"image_width,optional"` // 图片宽度
	ImageHeight    int    `json:"image_height,optional"` // 图片高度
}

// 角色皮肤信息
type ViewerOutfitItem {
	OutfitId    string                  `json:"outfit_id"` // 皮肤ID
	OutfitName  string                  `json:"outfit_name,optional"` // 皮肤名称
	Desc        string                  `json:"desc,optional"` // 描述
	MainColor   string                  `json:"main_color,optional"` // 主色
	Appearances []*ViewerAppearanceItem `json:"appearances"` // 外观列表
}

// 角色信息
type ViewerCharacterItem {
	CharacterId         string              `json:"character_id"` // 角色ID
	Name                string              `json:"name,optional"` // 角色名称
	Aka                 string              `json:"aka,optional"` // 角色称号
	Gender              string              `json:"gender,optional"` // 性别
	Species             string              `json:"species,optional"` // 物种
	Profile             string              `json:"profile,optional"` // 性格描述
	Relationship        string              `json:"relationship,optional"` // 关系
	VoiceId             string              `json:"voice_id,optional"` // 音色ID
	VoiceName           string              `json:"voice_name,optional"` // 音色名称
	CurrentOutfitId     string              `json:"current_outfit_id,optional"` // 当前皮肤ID
	CurrentAppearanceId string              `json:"current_appearance_id,optional"` // 当前外观ID
	Outfits             []*ViewerOutfitItem `json:"outfits,optional"` // 皮肤列表
}

// 角色列表请求
type ListViewerCharactersReq {
	Names []string `json:"names,optional"` // 可选：按角色名称过滤，不传则返回全部
}

// 角色列表响应
type ListViewerCharactersResp {
	Characters []*ViewerCharacterItem `json:"characters"` // 角色列表
}

// 物品外观信息
type ViewerSubjectAppearanceItem {
	AppearanceId   string `json:"appearance_id"` // 外观ID
	AppearanceName string `json:"appearance_name"` // 外观名称
	ImageUrl       string `json:"image_url,optional"` // 图片URL
	ImageWidth     int    `json:"image_width,optional"` // 图片宽度
	ImageHeight    int    `json:"image_height,optional"` // 图片高度
	Desc           string `json:"desc,optional"` // 描述
	EffectNames    string `json:"effect_names,optional"` // 特效名称
}

// 物品信息
type ViewerSubjectItem {
	SubjectId   string                         `json:"subject_id"` // 物品ID
	Name        string                         `json:"name,optional"` // 物品名称
	Aka         string                         `json:"aka,optional"` // 物品别名
	Gender      string                         `json:"gender,optional"` // 性别
	Species     string                         `json:"species,optional"` // 物种
	Profile     string                         `json:"profile,optional"` // 描述
	VoiceId     string                         `json:"voice_id,optional"` // 音色ID
	VoiceName   string                         `json:"voice_name,optional"` // 音色名称
	Appearances []*ViewerSubjectAppearanceItem `json:"appearances,optional"` // 外观列表
}

// 物品列表请求
type ListViewerSubjectsReq {}

// 物品列表响应
type ListViewerSubjectsResp {
	Subjects []*ViewerSubjectItem `json:"subjects"` // 物品列表
}

// Web Player 素材接口（不鉴权，供前端播放器使用）
@server (
	tags: "Web Player 素材接口"
)
service arca_api {
	// 获取素材列表
	@handler listViewerMaterials
	post /viewer/materials (ListViewerMaterialsReq) returns (ListViewerMaterialsResp)

	// 获取角色列表
	@handler listViewerCharacters
	post /viewer/characters (ListViewerCharactersReq) returns (ListViewerCharactersResp)

	// 获取物品列表
	@handler listViewerSubjects
	post /viewer/subjects (ListViewerSubjectsReq) returns (ListViewerSubjectsResp)
}

// 查看器：小手机消息分页响应
type ViewerUserPhoneChatMessagesResp {
	Msgs        []*PhoneMessageOutput `json:"msgs"`
	MinCursor   string                `json:"min_cursor"`
	MaxCursor   string                `json:"max_cursor"`
	UpHasMore   bool                  `json:"up_has_more"`
	DownHasMore bool                  `json:"down_has_more"`
}

// ==================== 推送设置模块类型定义 ====================
// 注册/更新设备推送 token 请求
// device_id 从请求头 belike-uuid 自动获取，无需客户端在 body 中传递
// os 从请求头 X-Platform 获取
type RegisterPushTokenReq {
	PushToken    string `json:"push_token"` // 推送 token：iOS(Expo/APNs) / Android(FCM)
	PushPlatform string `json:"push_platform"` // 推送平台: expo / apns / fcm
}

type RegisterPushTokenResp {
	Success bool `json:"success"`
}

// 注销设备推送 token 请求
// device_id 从请求头 belike-uuid 自动获取
type UnregisterPushTokenReq {}

type UnregisterPushTokenResp {
	Success bool `json:"success"`
}

// 更新推送设置请求（两个字段均为 optional，只传想改的）
// device_id 从请求头 belike-uuid 自动获取
type UpdatePushSettingsReq {
	PushEnabled       *bool `json:"push_enabled,optional"` // 是否启用推送（nil 表示不修改）
	QuietHoursEnabled *bool `json:"quiet_hours_enabled,optional"` // 是否开启夜间免打扰（nil 表示不修改）
}

type UpdatePushSettingsResp {
	Success bool `json:"success"`
}

// 查询当前设备推送设置请求
// device_id 从请求头 belike-uuid 自动获取
type GetPushSettingsReq {}

type GetPushSettingsResp {
	PushEnabled       bool `json:"push_enabled"` // 是否启用推送
	QuietHoursEnabled bool `json:"quiet_hours_enabled"` // 是否开启夜间免打扰
}

// 同步发送推送（测试用）
type SendPushSyncReq {
	UserID   string            `json:"user_id"` // 目标用户 ID（必填）
	PushType string            `json:"push_type,optional"` // 默认 system_notice
	Title    string            `json:"title"` // 推送标题
	Body     string            `json:"body"` // 推送正文
	Data     map[string]string `json:"data,optional"` // 自定义透传数据
	DeviceID string            `json:"device_id,optional"` // 指定设备；为空则推当前用户全部设备
}

type SendPushSyncResp {
	Success bool `json:"success"`
}

// 上报推送点击（客户端在点击系统通知后调用）
type ReportPushClickReq {
	PushLogID string `json:"push_log_id"` // push_notification_logs.id
}

type ReportPushClickResp {
	Success bool `json:"success"`
}

// 上报 App 前后台状态（用于推送抑制与在线态判断）
// device_id 从请求头 belike-uuid 自动获取；client_ip 由服务端从 X-Forwarded-For（取首个）/ X-Real-IP / RemoteAddr 解析，写入 Kafka 心跳事件，无需客户端传 body
type ReportAppStateReq {
	AppState  string `json:"app_state,options=foreground|background"` // App 状态：前台/后台
	EventType string `json:"event_type,optional,options=heartbeat|page_enter|page_leave|app_exit"` // 事件类型：心跳/页面进入/页面离开/退出 App
	PageName  string `json:"page_name,optional"` // 当前页面名（如 Home、ChatDetail）
	PagePath  string `json:"page_path,optional"` // 页面路径（如 /home、/chat/:id）
	SessionID string `json:"session_id,optional"` // 同一次启动会话 ID（客户端生成）
	ClientTs  int64  `json:"client_ts,optional"` // 客户端事件时间戳（Unix 秒）
	IsExit    bool   `json:"is_exit,optional"` // 是否显式退出 App（等价于 event_type=app_exit）
}

type ReportAppStateResp {
	Success          bool `json:"success"`
	ActiveInLastHour bool `json:"active_in_last_hour"` // 最近 1 小时内是否有前台活跃
}

// ==================== App 实时监控（arcaflow 消费心跳写入 Redis，此处仅查询）====================
type GetAppRTOverviewReq {
	Date string `json:"date,optional"` // yyyymmdd，默认上海时区今天
}

type AppRTPageDwellByPageRow {
	Rank     int64   `json:"rank"`
	PagePath string  `json:"page_path"`
	TotalSec float64 `json:"total_sec"`
}

type AppRTOverviewResp {
	ForegroundTerminals     int64                     `json:"foreground_terminals"` // 当前前台终端数（约 30 秒内有前台心跳的 uid:device）
	ForegroundUsers         int64                     `json:"foreground_users"` // 去重用户数（同上时间窗）
	EventCountsToday        map[string]int64          `json:"event_counts_today"` // 该 date 的事件计数（字段名保留向后兼容）
	Date                    string                    `json:"date"` // echo 实际使用的 date（yyyymmdd）
	OnlineSecRank           []AppRTRankingItem        `json:"online_sec_rank"` // 该 date 用户前台时长：date=今天时合并前台 ongoing，历史时只有已结算
	PageDwellByUser         []AppRTRankingItem        `json:"page_dwell_by_user"` // 该 date 用户页面停留总秒数 top N
	OnlineSecRankTotal      []AppRTRankingItem        `json:"online_sec_rank_total"` // 跨时段累计（不跟 date）
	InvitationPlayRankTotal []AppRTRankingItem        `json:"invitation_play_rank_total"` // 跨时段累计邀约
	PageDwellByPage         []AppRTPageDwellByPageRow `json:"page_dwell_by_page"` // 该 date 页面累计停留秒数 top N
}

type GetAppRTRankingsReq {
	Kind     string `json:"kind,options=online_sec|page_dwell"` // online_sec：当日 rank:online_sec:{date} + 前台未结算
	Date     string `json:"date,optional"` // yyyymmdd，默认今日（上海）
	PagePath string `json:"page_path,optional"` // kind=page_dwell 时可选，按页排行；空则按用户总停留
	Limit    int64  `json:"limit,optional"` // 默认 50，最大 500
}

type AppRTRankingItem {
	Uid           string  `json:"uid"`
	DisplayName   string  `json:"display_name,optional"` // 展示：用户名（手机号前三后四脱敏）；空则前端用 uid
	Score         float64 `json:"score"`
	Rank          int64   `json:"rank"`
	ForegroundNow bool    `json:"foreground_now,optional"` // 当前是否在前台（与 fg_terminals ~30s 窗口一致）
}

type GetAppRTRankingsResp {
	Kind     string             `json:"kind"`
	Date     string             `json:"date"`
	PagePath string             `json:"page_path"`
	RedisKey string             `json:"redis_key"`
	Items    []AppRTRankingItem `json:"items"`
}

type InternalRefreshGroupChatCoverResourceReq {
	SessionIds  []string `json:"session_ids,optional"` // 指定群聊 session_id 列表
	TemplateIds []string `json:"template_ids,optional"` // 指定群聊 template_id 列表（刷新 group_chat_template.cover_resource）
	Async       *bool    `json:"async,optional"` // 是否异步执行，默认 true；false=同步等待结果
	RefreshAll  bool     `json:"refresh_all,optional"` // true=刷新全部有效群聊
	Limit       int64    `json:"limit,optional"` // refresh_all=true 时可选，按 id 升序取前 N 条
	Concurrency int64    `json:"concurrency,optional"` // 并发数，默认 8，最大 32
}

type InternalRefreshGroupChatCoverResourceFailure {
	SessionId  string `json:"session_id,optional"`
	TemplateId string `json:"template_id,optional"`
	Error      string `json:"error"`
}

type InternalRefreshGroupChatCoverResourceResp {
	Accepted          bool                                           `json:"accepted"` // async=true 时表示任务已接收
	Async             bool                                           `json:"async"` // 本次执行模式
	RefreshAll        bool                                           `json:"refresh_all"`
	Total             int64                                          `json:"total"`
	Success           int64                                          `json:"success"`
	Failed            int64                                          `json:"failed"`
	Failures          []InternalRefreshGroupChatCoverResourceFailure `json:"failures,optional"`
	FailuresTruncated bool                                           `json:"failures_truncated,optional"`
}

// 无鉴权，仅内网 / 网关白名单暴露（与 internal/tool 同类）
@server (
	tags:    "（无鉴权）内部接口-App 实时监控"
	timeout: 0s
)
service arca_api {
	@handler internalGetAppRTOverview
	post /internal/app_rt/overview (GetAppRTOverviewReq) returns (AppRTOverviewResp)

	@handler internalGetAppRTRankings
	post /internal/app_rt/rankings (GetAppRTRankingsReq) returns (GetAppRTRankingsResp)
// @handler internalRefreshGroupChatCoverResource
// post /internal/group_chat/refresh_cover_resource (InternalRefreshGroupChatCoverResourceReq) returns (InternalRefreshGroupChatCoverResourceResp)
}

@server (
	tags: "推送测试模块"
)
service arca_api {
	// 同步发送推送（测试接口，无需鉴权）
	@handler sendPushSync
	post /app/send_push_sync (SendPushSyncReq) returns (SendPushSyncResp)
}

// ==================== 推送设置模块（鉴权） ====================
@server (
	jwt:      Auth // 开启 jwt 认证
	authType: apiKey
	tags:     "推送设置模块"
)
service arca_api {
	// 注册/更新设备推送 token
	@handler registerPushToken
	post /app/register_push_token (RegisterPushTokenReq) returns (RegisterPushTokenResp)

	// 注销设备推送 token
	@handler unregisterPushToken
	post /app/unregister_push_token (UnregisterPushTokenReq) returns (UnregisterPushTokenResp)

	// 更新推送设置（推送开关 / 夜间免打扰）
	@handler updatePushSettings
	post /app/update_push_settings (UpdatePushSettingsReq) returns (UpdatePushSettingsResp)

	// 查询当前设备的推送设置
	@handler getPushSettings
	post /app/get_push_settings (GetPushSettingsReq) returns (GetPushSettingsResp)

	// 上报推送点击状态
	@handler reportPushClick
	post /app/report_push_click (ReportPushClickReq) returns (ReportPushClickResp)
}

// ==================== 动态（post）模块（v4.9） ====================
// 产品形态：用户 UGC 动态 + 角色 AIGC 动态共用 post 表，由 author_type 区分
// - 用户动态：客户端直接调用 /post/create → /post/publish
// - 角色动态：AIGC 驱动，由 arcaflow 任务 TaskTypeGenerateCharacterPost 写入，
//   不走客户端链路（客户端只读）
// ---------- 共享结构 ----------
type PostAuthor {
	AuthorType  int32  `json:"author_type,options=1|2"` // 1-user 2-character
	AuthorId    string `json:"author_id"` // user_id 或 character_id（polymorphic）
	DisplayName string `json:"display_name,optional"` // 渲染用
	Avatar      *Media `json:"avatar,optional"` // 渲染用；user 作者暂无头像源 → nil
}

type PostLinkedItem {
	ItemType        int32    `json:"item_type,options=1|2|3"` // 1-character 2-script 3-group_chat
	ItemId          string   `json:"item_id"` // character_id / script_id / group_chat_template_id
	Cover           *Media   `json:"cover,optional"`
	Title           string   `json:"title,optional"`
	Content         string   `json:"content"`
	PlayID          *string  `json:"play_id,omitempty"`
	GroupSessionID  *string  `json:"group_session_id,optional"`
	ScriptOpeningID *string  `json:"script_opening_id,optional"`
	Reachable       *bool    `json:"reachable,optional"` // 用户是否有权限访问
	Tags            []string `json:"tags,optional"` // 标签（character 关联项为性格标签中文原文，作内部 key 用）
	TagsName        []string `json:"tags_name,optional"` // 标签展示名（character 关联项按 X-Language 翻译，与 tags 一一对应；group_chat 关联项为简介自由文本，不翻译）
}

type PostInfo {
	PostId       string           `json:"post_id"`
	Author       PostAuthor       `json:"author"`
	Title        string           `json:"title,optional"`
	Content      string           `json:"content,optional"`
	Images       []*Media         `json:"images,optional"`
	Bgm          *Media           `json:"bgm,optional"`
	Visibility   int32            `json:"visibility,options=1|2|3"` // 1-公开 2-仅好友 3-私密
	LinkedItems  []PostLinkedItem `json:"linked_items,optional"`
	Status       int32            `json:"status,options=1|2|3"` // 1-draft 2-published 3-deleted
	LikeCount    int64            `json:"like_count"`
	CommentCount int64            `json:"comment_count"`
	IsLiked      bool             `json:"is_liked,optional"` // 当前用户是否已点赞
	PublishedAt  int64            `json:"published_at,optional"`
	CreatedAt    int64            `json:"created_at"`
}

// ---------- post 接口 ----------
type CreatePostReq {
	Title       string           `json:"title,optional"`
	Content     string           `json:"content,optional"`
	Images      []*Media         `json:"images,optional"` // 客户端上传 TOS 后传 url（其他字段可空）
	Visibility  int32            `json:"visibility,options=1|2|3"` // 1公开2好友可见3私密
	AllowList   []string         `json:"allowlist,optional"`
	BlockList   []string         `json:"blocklist,optional"`
	BgmMusicKey *string          `json:"bgm_music_key,optional"`
	LinkedItems []PostLinkedItem `json:"linked_items,optional"` // 国内功能，已下线
}

// 返回 draft 状态的 post_id；还需再调 /post/publish 才可见
type CreatePostResp {
	PostId string `json:"post_id"`
}

type PublishPostReq {
	PostId string `json:"post_id"`
}

type PublishPostResp {
	PostId      string `json:"post_id"`
	PublishedAt int64  `json:"published_at"`
}

type DeletePostReq {
	PostId string `json:"post_id"`
}

type DeletePostResp {}

type GetPostDetailReq {
	PostId       string `json:"post_id"`
	Source       string `json:"source,optional"` // 进入来源页枚举：feed / user_page / character_page / notification / direct
	ImpressionId string `json:"impression_id,optional"` // source=feed 时带上本次曝光的 impression_id，用于回流统计
}

type GetPostDetailResp {
	Post PostInfo `json:"post"`
}

type UpdatePostVisibilityReq {
	PostId     string `json:"post_id"`
	Visibility int32  `json:"visibility,options=1|2|3"`
}

type UpdatePostVisibilityResp {
	PostId string `json:"post_id"`
}

type ListMyDraftPostsReq {
	Cursor string `json:"cursor,optional"` // id DESC 游标（last id 字符串）
	Limit  int    `json:"limit,optional"` // 默认 20
}

type ListMyDraftPostsResp {
	Posts      []PostInfo `json:"posts"`
	NextCursor string     `json:"next_cursor"`
	HasMore    bool       `json:"has_more,optional"`
}

type ListPublishedPostsReq {
	UserId string `json:"user_id,optional"` // 要查的用户；空 = 当前用户
	Cursor string `json:"cursor,optional"` // (published_at, id) 复合游标
	Limit  int    `json:"limit,optional"` // 默认 20
}

type ListPublishedPostsResp {
	Posts      []PostInfo `json:"posts"`
	NextCursor string     `json:"next_cursor"`
	HasMore    bool       `json:"has_more,optional"`
}

type ListPostsByCharacterReq {
	CharacterId string `json:"character_id"` // 既查 author_type=2 & author_id=X（character 发的），
	// 也查 linked_items 含该 character 的（可选合并，初版只查前者）
	Cursor string `json:"cursor,optional"`
	Limit  int    `json:"limit,optional"`
}

type ListPostsByCharacterResp {
	Posts      []PostInfo `json:"posts"`
	NextCursor string     `json:"next_cursor"`
	HasMore    bool       `json:"has_more,optional"`
}

@server (
	jwt:      Auth
	authType: apiKey
	group:    post
	tags:     "动态模块"
	timeout:  60s
)
service arca_api {
	// 创建 draft（不发布，可反复编辑）
	@handler createPost
	post /post/create (CreatePostReq) returns (CreatePostResp)

	// 发布（draft → published），此后进入 feed 与作者主页
	@handler publishPost
	post /post/publish (PublishPostReq) returns (PublishPostResp)

	// 软删除（仅作者）
	@handler deletePost
	post /post/delete (DeletePostReq) returns (DeletePostResp)

	// 详情（含关联角色/剧本、计数、当前用户的点赞状态）
	@handler getPostDetail
	post /post/detail (GetPostDetailReq) returns (GetPostDetailResp)

	// 切换可见性：public / friends_only / private
	@handler updatePostVisibility
	post /post/update_visibility (UpdatePostVisibilityReq) returns (UpdatePostVisibilityResp)

	// 我的草稿箱（status=draft，仅当前用户）
	@handler listMyDraftPosts
	post /post/list_drafts (ListMyDraftPostsReq) returns (ListMyDraftPostsResp)

	// 某用户的已发布动态（status=published）；user_id 空 = 当前用户
	@handler listPublishedPosts
	post /post/list_published (ListPublishedPostsReq) returns (ListPublishedPostsResp)

	// 某角色页相关动态
	@handler listPostsByCharacter
	post /post/list_by_character (ListPostsByCharacterReq) returns (ListPostsByCharacterResp)
}

type AppearanceMedia {
	Thumbnail *Media `json:"thumbnail,optional"`
	Card      *Media `json:"card,optional"`
	Detail    *Media `json:"detail,optional"`
}

// ========================== reaction（点赞 / 收藏）==========================
// 3 类目标（character/post/story）共用一套"反应"体系
// 只上 kind=like；kind=collect 留后续 spec
// target_type 枚举：1-character 2-post 3-story
type ReactionAddReq {
	TargetType   int32   `json:"target_type,options=1|2|3"` // 1-character 2-post 3-story
	TargetId     string  `json:"target_id"` // 目标业务 ID // character_id/post_id/story_id
	Kind         int32   `json:"kind,optional,options=1|2"` // 1-like（默认） 2-collect（暂不开放）
	ImpressionId *string `json:"impression_id,optional"` // feed/search 展现id
}

type ReactionAddResp {
	LikeCount int32 `json:"like_count"` // 操作后目标的最新点赞数（仅 kind=like 时有意义）
}

type ReactionRemoveReq {
	TargetType int32  `json:"target_type,options=1|2|3"` // 1-character 2-post 3-story
	TargetId   string `json:"target_id"` // character_id/post_id/story_id
	Kind       int32  `json:"kind,optional,options=1|2"`
}

type ReactionRemoveResp {
	LikeCount int32 `json:"like_count"` // 操作后目标的最新点赞数
}

type GetReactionForTargetReq {
	TargetType int32    `json:"target_type,options=1|2|3"` // 1-character 2-post 3-story
	TargetIds  []string `json:"target_ids"` // 一次查多个目标（单 target_type 下）
	Kind       int32    `json:"kind,optional,options=1|2"` // 默认 1-like
}

type ReactionStatus {
	TargetId  string `json:"target_id"`
	IsLiked   bool   `json:"is_liked"`
	LikeCount int32  `json:"like_count"`
}

type GetReactionForTargetResp {
	Statuses []ReactionStatus `json:"statuses"`
}

@server (
	jwt:      Auth
	authType: apiKey
	group:    reaction
	tags:     "反应（点赞/收藏）"
	timeout:  30s
)
service arca_api {
	// 点赞（幂等；已点过则直接返回当前 like_count）
	@handler addReaction
	post /reaction/add (ReactionAddReq) returns (ReactionAddResp)

	// 取消点赞（幂等；未点过直接返回）
	@handler removeReaction
	post /reaction/remove (ReactionRemoveReq) returns (ReactionRemoveResp)

	// 批量查当前用户对一批 target 的 like 状态 + like_count
	@handler getReactionForTarget
	post /reaction/get_for_target (GetReactionForTargetReq) returns (GetReactionForTargetResp)
}

// ========================== comment（评论 / 回复）==========================
// 场景：post 评论闭环；v4.9.1 接入 AIGC 角色评论 4 条链路
// 设计：
//   - DB 平铺嵌套：root_comment_id 平铺挂载，parent_comment_id 仅承载 UI "回复 @xxx"
//   - 软删保子代：父评论软删后子代仍可见，父以占位形式存在
//   - 多态 author / target，复用 PostAuthor 渲染
//   - publish_at 定时发布：AIGC 评论 = 未来时刻，read path 必须 publish_at <= now()
//   - 评论点赞已下线：reaction target_type 枚举收敛为 1-character 2-post 3-story，comment 不再可点赞
// 详见 docs: comment.md
type CommentMentionInfo {
	Name        string  `json:"name"`
	UserID      *string `json:"user_id,optional"`
	CharacterID *string `json:"character_id,optional"`
}

type CommentItem {
	CommentId            string               `json:"comment_id"`
	TargetType           int32                `json:"target_type,options=1"` // 1-post（v4.9 起步）
	TargetId             string               `json:"target_id"`
	Author               PostAuthor           `json:"author"` // 复用 PostAuthor 多态结构
	ParentCommentId      string               `json:"parent_comment_id,optional"` // UI 直接父；空=一级
	RootCommentId        string               `json:"root_comment_id,optional"` // 平铺挂载点；空=一级
	ParentAuthorNickname string               `json:"parent_author_nickname,optional"` // "回复 @xx" 快照
	Content              string               `json:"content,optional"` // 文字内容（可空：纯图/表情）
	Images               []*Media             `json:"images,optional"` // image_resources 批量回填
	Mentions             []CommentMentionInfo `json:"mentions,optional"` // @ 列表
	LikeCount            int64                `json:"like_count"`
	ReplyCount           int64                `json:"reply_count"` // 仅一级评论有意义
	IsLiked              bool                 `json:"is_liked,optional"`
	ReplyPreview         []CommentItem        `json:"reply_preview,optional"` // list_by_post 时填，前 2 条 reply
	PublishAt            int64                `json:"publish_at"` // Unix 秒，AIGC 评论可能是未来时刻
	CreatedAt            int64                `json:"created_at"`
}

type CreateCommentReq {
	TargetType      int32                `json:"target_type,options=1"` // 1-post（v4.9 起步）
	TargetId        string               `json:"target_id"` // post_id
	Content         string               `json:"content,optional"` // 文字（content/images 至少一个非空）
	Mentions        []CommentMentionInfo `json:"mentions,optional"`
	Images          []string             `json:"images,optional"` // [url, ...]
	ParentCommentId string               `json:"parent_comment_id,optional"` // 空=直评 post；非空=reply
}

type CreateCommentResp {
	CommentId    string `json:"comment_id"`
	CreatedAt    int64  `json:"created_at"` // Unix 秒
	CommentCount int64  `json:"comment_count"` // 操作后 post 的最新评论数
}

type DeleteCommentReq {
	CommentId string `json:"comment_id"`
}

type DeleteCommentResp {
	CommentCount int64 `json:"comment_count"` // 操作后 post 的最新评论数
}

type ListCommentsByPostReq {
	PostId          string `json:"post_id"`
	Cursor          string `json:"cursor,optional"` // base64(json{publish_at_ns, id}) 复合游标
	AnchorCommentID string `json:"anchor_comment_id,optional"`
	Limit           int    `json:"limit,optional"` // 默认 20，上限 100
}

type ListCommentsByPostResp {
	Comments   []CommentItem `json:"comments"` // 一级评论 + 各自 reply_preview
	NextCursor string        `json:"next_cursor,optional"`
	HasMore    bool          `json:"has_more"`
}

type ListRepliesByCommentReq {
	CommentId       string   `json:"comment_id"` // 必须是一级评论 (root_comment_id IS NULL)
	Cursor          string   `json:"cursor,optional"` // base64(json{publish_at_ns, id}) ASC 复合游标
	ExistCommentIDs []string `json:"exist_comment_ids,optional"`
	Limit           int      `json:"limit,optional"` // 默认 20，上限 100
}

type ListRepliesByCommentResp {
	Replies    []CommentItem `json:"replies"` // 平铺所有 reply（含 reply-of-reply），含软删占位
	NextCursor string        `json:"next_cursor,optional"`
	HasMore    bool          `json:"has_more"`
}

@server (
	jwt:      Auth
	authType: apiKey
	group:    comment
	tags:     "评论模块"
	timeout:  30s
)
service arca_api {
	// 创建评论 / 回复
	// - 直评：parent_comment_id 空
	// - reply：parent_comment_id 指向某一级或某 reply（root_comment_id 由后端解析挂到一级）
	// 副作用：post.comment_count++ / 写 inbox (post_comment / post_comment_reply / mention)
	//        / 若 post.author_type=2 → 投递 AIGC watch task / 若 mentions 含 character → 投递 mention task
	@handler createComment
	post /comment/create (CreateCommentReq) returns (CreateCommentResp)

	// 软删评论（评论作者 或 post 作者可删）
	// 副作用：post.comment_count-- / root.reply_count-- / 联动软删未读 inbox
	@handler deleteComment
	post /comment/delete (DeleteCommentReq) returns (DeleteCommentResp)

	// 拉某 post 下的一级评论列表（含每条前 N=2 条 reply preview）
	// 按 publish_at DESC, id DESC；隐藏未到 publish_at 的 AIGC 评论；保留 deleted 但有 reply 的占位行
	@handler listCommentsByPost
	post /comment/list_by_post (ListCommentsByPostReq) returns (ListCommentsByPostResp)

	// 拉某一级评论下全部 reply（平铺，按 publish_at ASC 时间线）
	// 含软删 reply 的占位渲染，保 thread 完整
	@handler listRepliesByComment
	post /comment/list_replies (ListRepliesByCommentReq) returns (ListRepliesByCommentResp)
}

// ========================== inbox（收件箱 / 红点）==========================
// 场景：系统级通知载体，v4.9 MVP 承载 friend_request（角色请求加你为好友）
// 前端使用：
//   - 首屏 & 周期性拉 /inbox/list 展示红点
//   - 用户点"接受"friend_request → 客户端直接调 /character/create?source_character_id=<sender_id> 复制出自己的角色（arca 不在此处做状态机）
//   - 用户查看后调 /inbox/update_read_status 消红点
type InboxMessageButton {
	Text       string `json:"text"`
	Clickable  bool   `json:"clickable,optional"`
	ActionType int32  `json:"action_type,optional"` // 0=未操作 1=已添加
	ActedAt    int64  `json:"acted_at,optional"` // Unix 秒；未操作时缺省
}

type InboxMessage {
	MsgId      string               `json:"msg_id"`
	MsgType    string               `json:"msg_type,options=friend_request|interation"` // 'friend_request'（可扩展）
	SenderInfo InboxSenderInfo      `json:"sender_info"`
	SourceInfo *InboxSourceInfo     `json:"source_info,optional"`
	Title      string               `json:"title"`
	Content    string               `json:"content"` // 可含 "{@:user_id:xxx}" / "{@:character_id:xxx}" 占位符，前端按 Mentions 渲染
	Options    []InboxMessageButton `json:"options,optional"`
	Mentions   []CommentMentionInfo `json:"mentions,optional"` // 评论 mentions 数组快照；非评论事件 inbox 为 nil
	IsRead     bool                 `json:"is_read,optional"`
	CreatedAt  int64                `json:"created_at"`
}

type InboxSenderInfo {
	SenderId   string `json:"sender_id"` // user_id/character_id
	SenderName string `json:"sender_name"`
	SenderType int32  `json:"sender_type,options=1|2|3"` // 1-user 2-character 3-system
	Avatar     *Media `json:"avatar"` //
}

type InboxSourceInfo {
	SourceID   string  `json:"source_id"` // script_id/character_id|post_id|group_chat_template_id|comment_id
	SourceType string  `json:"source_type,options=script|character|post|group_chat|comment"`
	ScopeID    *string `json:"scope_id,optional"` // 当前只可能是 post_id
	ScopeType  *string `json:"scope_type,optional,options=script"` // Source所属的Scope, comment 的 scope 目前只有 post
	Cover      *Media  `json:"cover"`
}

type ListInboxReq {
	Cursor     string `json:"cursor,optional"`
	Limit      int    `json:"limit,optional,default=20"`
	MsgType    string `json:"msg_type,optional"` // 可选：只看某类通知
	UnreadOnly bool   `json:"unread_only,optional"` // 可选：只看未读
}

type ListInboxResp {
	Messages   []InboxMessage `json:"messages"`
	NextCursor string         `json:"next_cursor,optional"`
	HasMore    bool           `json:"has_more"`
}

type UpdateInboxReadStatusReq {
	MsgIds []string `json:"msg_ids"` // 要改状态的 msg_id 列表（同用户）
	IsRead bool     `json:"is_read,optional,default=true"` // true=已读（默认），false=未读
}

type UpdateInboxReadStatusResp {}

// v4.9.1：对 actionable msg_type（首批：friend_request）落"同意 / 拒绝"两态
// 行为：已操作过的消息再调本接口走幂等成功路径，返回原 acted_at；msg 不存在或非当前用户返回 not_found
type UpdateInboxActionStatusReq {
	MsgId      string `json:"msg_id"` // 必填：要落状态的消息
	ActionType int32  `json:"action_type,options=1|2"` // 1=同意 2=拒绝
}

type UpdateInboxActionStatusResp {
	ActedAt int64 `json:"acted_at"` // Unix 秒
}

// 手动投递一条 inbox 消息（调试 / 管理 / 业务侧手动触发通知用）
// 正常业务请走各 SubmitXxx（如 SubmitCharacterFriendRequest）；本接口只直通写库，不跑 AIGC
// 幂等：friend_request 按 (user_id, sender_type, sender_id, msg_type, is_deleted=0, is_read=0) 去重
type AppendInboxMessageReq {
	UserId     string `json:"user_id"` // 收件用户
	MsgType    string `json:"msg_type"` // 'friend_request'（可扩展）
	SenderType int32  `json:"sender_type,options=1|2|3"` // 1-user 2-character 3-system
	SenderId   string `json:"sender_id"` // 多态：user_id / character_id
	SourceType string `json:"source_type,optional"` // 'group_chat_session' / 'play' / 'script' / 其它
	SourceId   string `json:"source_id,optional"` // 对应业务 ID
	Body       string `json:"body"` // 已序列化 JSON 字符串（前端 / 调用方自己拼）
}

type AppendInboxMessageResp {
	MsgId string `json:"msg_id"`
}

// 拉取当前用户未读消息数（首屏红点 badge + 各 msg_type tab 分桶红点）
// 实时性"分钟级"即可，服务端按 user_id 走 Redis cache-aside，TTL 60s；不主动失效
type GetInboxUnreadCountReq {}

type GetInboxUnreadCountResp {
	Total     int32            `json:"total"` // 全部 msg_type 之和（is_deleted=0 AND is_read=0 AND 未过期）
	ByMsgType map[string]int32 `json:"by_msg_type"` // 按 msg_type 分桶；key=msg_type, value=该类型未读数；用户无消息时返回 {}
}

// ==================== PGC 数据导入（role_exports）内部接口 ====================
// 异步任务：扫描 TOS role_exports 目录、写 character/script 域、跨桶搬 PNG、写 resource_media。
// 进度写 Redis（前端 /admin/dataops 页面通过 /status / /recent 轮询；/cancel 触发中断）。
// (region, script_title) 精确过滤对（dry_run preview 多选 → 实际执行用）
type ImportRoleExportsScriptPair {
	Region      string `json:"region"`
	ScriptTitle string `json:"script_title"`
}

// 单张图的尺寸覆盖：按 SrcTosUrl 全字符串匹配；命中后写 resource_media.width/height
type ImportRoleExportsImageDimOverride {
	SrcTosUrl string `json:"src_tos_url"`
	Width     int    `json:"width"`
	Height    int    `json:"height"`
}

// 单张图的人脸框覆盖：坐标基于"用户改过的 W/H 画布"像素（与 face_detection.json 同语义）；
// 命中后写 resource_media.face_box，替换 face_detection.json 原始 bestFace 值。
// 支持 face_count=0 的图（运维补人脸框）：runner 见到 override 就直接落 face_box，不读 face_detection 的 bestFace。
type ImportRoleExportsFaceBoxOverride {
	SrcTosUrl  string `json:"src_tos_url"`
	FaceLeft   int    `json:"face_left"`
	FaceTop    int    `json:"face_top"`
	FaceRight  int    `json:"face_right"`
	FaceBottom int    `json:"face_bottom"`
}

// 启动一次 PGC 导入任务
type ImportRoleExportsStartReq {
	TosPrefix         string                              `json:"tos_prefix"` // 源桶扫描入口，结尾保留 "/"
	ScriptTitles      []string                            `json:"script_titles,optional"` // 仅刷指定剧本时填；为空则全扫
	Regions           []string                            `json:"regions,optional"` // 仅扫指定 region（JP / KR），为空则全扫
	ScriptPairs       []ImportRoleExportsScriptPair       `json:"script_pairs,optional"` // 精确 (region, script_title) 列表；非空时覆盖 script_titles + regions 笛卡尔积
	DryRun            bool                                `json:"dry_run,optional"` // 仅扫描预览，不写 DB / 不搬运 PNG
	SkipCopy          bool                                `json:"skip_copy,optional"` // 跳过跨桶搬运，直接用源 URL 写 resource_media
	SkipScript        bool                                `json:"skip_script,optional"` // 仅生成角色，不读 scripts.json、不写 script / script_version / script_role / script_opening_log
	PreviewAIGC       bool                                `json:"preview_aigc,optional"` // dry_run preview 时是否调 AIGC ConvertOpeningLog 做规范化；前端默认勾选
	ImageDimOverrides []ImportRoleExportsImageDimOverride `json:"image_dim_overrides,optional"` // 按源 tos_url 覆盖 resource_media.width/height；缺省走 1080×1920
	FaceBoxOverrides  []ImportRoleExportsFaceBoxOverride  `json:"face_box_overrides,optional"` // 按源 tos_url 覆盖 resource_media.face_box；坐标系基于对应 ImageDimOverrides 画布
}

type ImportRoleExportsStartResp {
	TaskId string `json:"task_id"`
}

// 查询任务进度
type ImportRoleExportsStatusReq {
	TaskId string `json:"task_id"`
}

// 进度成功项：单 (region, script) 下成功落库的角色名列表
type ImportRoleExportsSucceededItem {
	Script     string   `json:"script,optional"`
	Region     string   `json:"region,optional"`
	Characters []string `json:"characters"`
}

// 进度失败项：定位到 stage（scan / tos_read / tos_copy / parse / db_write / convert_opening_log 等）
type ImportRoleExportsFailedItem {
	Script string `json:"script,optional"`
	Region string `json:"region,optional"`
	Role   string `json:"role,optional"`
	Stage  string `json:"stage"`
	Reason string `json:"reason"`
}

// dry_run 人脸框预览：让前端按 face_rect 画框校验切割位置
type ImportRoleExportsFaceCropPreview {
	AppearanceName string  `json:"appearance_name"`
	Filename       string  `json:"filename"`
	SrcTosUrl      string  `json:"src_tos_url"`
	FaceCount      int     `json:"face_count"`
	FaceScore      float64 `json:"face_score"`
	FaceLeft       int     `json:"face_left"`
	FaceTop        int     `json:"face_top"`
	FaceRight      int     `json:"face_right"`
	FaceBottom     int     `json:"face_bottom"`
}

// dry_run 预览：单角色将要写入每张表的全字段（map 类型保留原 column 名 → 值映射）
type ImportRoleExportsPreviewRole {
	RoleName                string                             `json:"role_name"`
	Name                    string                             `json:"name,optional"`
	AbilitiesCount          int                                `json:"abilities_count"`
	SkillsCount             int                                `json:"skills_count"`
	SocialLinksCount        int                                `json:"social_links_count"`
	AppearancesCount        int                                `json:"appearances_count"`
	PngsToCopy              int                                `json:"pngs_to_copy"`
	CharacterRow            map[string]interface{}             `json:"character_row,optional"`
	DetailSettingRow        map[string]interface{}             `json:"detail_setting_row,optional"`
	OutfitRow               map[string]interface{}             `json:"outfit_row,optional"`
	AppearanceRows          []map[string]interface{}           `json:"appearance_rows,optional"`
	AbilityRows             []map[string]interface{}           `json:"ability_rows,optional"`
	SkillRows               []map[string]interface{}           `json:"skill_rows,optional"`
	PreMadeRelationshipRows []map[string]interface{}           `json:"pre_made_relationship_rows,optional"`
	FaceCrops               []ImportRoleExportsFaceCropPreview `json:"face_crops,optional"`
}

// dry_run 预览：单剧本将要写入每张表的全字段 + role 列表
type ImportRoleExportsPreviewScript {
	Region              string                         `json:"region"`
	ScriptTitle         string                         `json:"script_title"`
	StoryTitle          string                         `json:"story_title,optional"`
	ChaptersCount       int                            `json:"chapters_count"`
	NarrativesCount     int                            `json:"narratives_count"`
	RolesCount          int                            `json:"roles_count"`
	Roles               []ImportRoleExportsPreviewRole `json:"roles"`
	ScriptRow           map[string]interface{}         `json:"script_row,optional"`
	ScriptVersionRow    map[string]interface{}         `json:"script_version_row,optional"`
	ScriptRoleRows      []map[string]interface{}       `json:"script_role_rows,optional"`
	OpeningLogSample    []map[string]interface{}       `json:"opening_log_sample,optional"`
	OpeningLogTotalRows int                            `json:"opening_log_total_rows"`
}

// dry_run 预览：整任务汇总
type ImportRoleExportsPreview {
	TotalScripts       int                              `json:"total_scripts"`
	TotalCharacters    int                              `json:"total_characters"`
	TotalAppearances   int                              `json:"total_appearances"`
	TotalResourceMedia int                              `json:"total_resource_media"`
	TotalNarratives    int                              `json:"total_narratives"`
	Scripts            []ImportRoleExportsPreviewScript `json:"scripts"`
}

// 状态响应：任务整体进度 + 成功 / 失败 / preview
type ImportRoleExportsStatusResp {
	TaskId          string                           `json:"task_id"`
	State           string                           `json:"state"` // running / done / failed / cancelled / not_found
	StartedAt       int64                            `json:"started_at"`
	UpdatedAt       int64                            `json:"updated_at"`
	DryRun          bool                             `json:"dry_run"`
	CancelRequested bool                             `json:"cancel_requested"`
	TotalScripts    int                              `json:"total_scripts"`
	DoneScripts     int                              `json:"done_scripts"`
	TotalCharacters int                              `json:"total_characters"`
	DoneCharacters  int                              `json:"done_characters"`
	TotalPngs       int                              `json:"total_pngs"`
	DonePngs        int                              `json:"done_pngs"`
	CurrentRegion   string                           `json:"current_region,optional"`
	CurrentScript   string                           `json:"current_script,optional"`
	CurrentRole     string                           `json:"current_role,optional"`
	CurrentStage    string                           `json:"current_stage,optional"` // scanning / fetch_script_json / fetch_character_json / copy_pngs / convert_opening_log / write_db / done
	Succeeded       []ImportRoleExportsSucceededItem `json:"succeeded"`
	Failed          []ImportRoleExportsFailedItem    `json:"failed"`
	Preview         *ImportRoleExportsPreview        `json:"preview,optional"`
}

// 中断任务（幂等：已终态时返回 accepted=false）
type ImportRoleExportsCancelReq {
	TaskId string `json:"task_id"`
}

type ImportRoleExportsCancelResp {
	TaskId   string `json:"task_id"`
	Accepted bool   `json:"accepted"` // true=已下发中断标志；false=任务已终态、无需中断
}

// 最近任务列表（全员共享 ZSET，前端 /admin/dataops 侧栏使用）
type ImportRoleExportsRecentReq {
	Limit int `json:"limit,optional"` // 默认 20，最大 50
}

// 最近任务条目：与 status 接口同字段子集，便于前端不用为每条记录再查一次 /status
type ImportRoleExportsRecentItem {
	TaskId          string `json:"task_id"`
	State           string `json:"state"`
	StartedAt       int64  `json:"started_at"`
	UpdatedAt       int64  `json:"updated_at"`
	DryRun          bool   `json:"dry_run"`
	CancelRequested bool   `json:"cancel_requested"`
	TotalScripts    int    `json:"total_scripts"`
	DoneScripts     int    `json:"done_scripts"`
	TotalCharacters int    `json:"total_characters"`
	DoneCharacters  int    `json:"done_characters"`
}

type ImportRoleExportsRecentResp {
	Items []ImportRoleExportsRecentItem `json:"items"`
}

// 无鉴权内部接口（与 /admin/dataops 页面配套，由内网调用）
@server (
	tags:    "（无鉴权）内部接口-PGC 数据导入"
	timeout: 0s
)
service arca_api {
	// 启动一次 PGC role_exports 导入任务（dry_run / 正式 / skipCopy / skipScript / previewAIGC 通过 body 控制）
	@handler internalImportRoleExportsStart
	post /internal/import/role_exports/start (ImportRoleExportsStartReq) returns (ImportRoleExportsStartResp)

	// 查询单任务的实时进度（前端 1s 轮询）
	@handler internalImportRoleExportsStatus
	post /internal/import/role_exports/status (ImportRoleExportsStatusReq) returns (ImportRoleExportsStatusResp)

	// 请求中断（幂等：已终态返回 accepted=false；runner 在循环边界检查后切到 cancelled 终态）
	@handler internalImportRoleExportsCancel
	post /internal/import/role_exports/cancel (ImportRoleExportsCancelReq) returns (ImportRoleExportsCancelResp)

	// 全员共享的"最近任务"列表（按提交时间倒序；前端侧栏 5s 轮询）
	@handler internalImportRoleExportsRecent
	post /internal/import/role_exports/recent (ImportRoleExportsRecentReq) returns (ImportRoleExportsRecentResp)
}

// ========================== story（限时动态）==========================
// 角色限时动态：仿 Instagram Stories 的发布 / 头条 / 查看 / 已读上报。
// 客户端入口：feed 顶部 headline 横滚 → 点角色头像进 viewer 全屏轮播 → 滑动间隔上报 view mark。
type StoryHeadlineReq {}

type StoryHeadlineItem {
	CharacterId       string   `json:"character_id"`
	CharacterName     string   `json:"character_name"`
	Avatar            Media    `json:"avatar"`
	Region            string   `json:"region"`
	Unread            bool     `json:"unread"`
	StoryCount        int      `json:"story_count"`
	LatestPublishedAt int64    `json:"latest_published_at"`
	StoryIds          []string `json:"story_ids"`
}

type StoryHeadlineResp {
	State string              `json:"state,options=hidden|empty|normal"`
	Items []StoryHeadlineItem `json:"items"`
}

type StoryViewerReq {
	CharacterId string `form:"character_id"`
}

type StoryViewerStory {
	StoryId     string `json:"story_id"`
	Content     string `json:"content"`
	ContentType string `json:"content_type"` // post
	ContentID   string `json:"content_id"` // post_id
	Image       *Media `json:"image,omitempty"`
	Bgm         *Media `json:"bgm,omitempty"`
	BgmMeta     string `json:"bgm_meta,omitempty"`
	PublishedAt int64  `json:"published_at"`
	ExpireAt    int64  `json:"expire_at"`
	Viewed      bool   `json:"viewed"`
	Liked       bool   `json:"liked"`
}

type StoryViewerResp {
	Stories       []StoryViewerStory `json:"stories"`
	StartIndex    int                `json:"start_index"`
	CharacterId   string             `json:"character_id"`
	CharacterName string             `json:"character_name"`
}

type StoryViewMarkReq {
	StoryId string `json:"story_id"`
}

type StoryViewMarkResp {
	Ok bool `json:"ok"`
}

type StoryCommentReq {
	StoryID *string `json:"story_id,optional,omitempty"`
	PostID  *string `json:"post_id,optional,omitempty"`
	Content string  `json:"content"`
}

type StoryCommentResp {
	CommentId       string            `json:"comment_id"`
	CharacterSaveID string            `json:"character_save_id"`
	Charged         int               `json:"charged"`
	WalletStatus    *WalletStatusInfo `json:"wallet_status,omitempty"` // 扣费成功后的低余额软提醒；钱包未挂载/查询失败时省略
}

type StoryLikeReq {
	StoryId string `json:"story_id"`
}

type StoryLikeResp {
	IsNewLike      bool    `json:"is_new_like"`
	IsDuplicate    bool    `json:"is_duplicate"`
	LlmTriggered   bool    `json:"llm_triggered"`
	Probability    float64 `json:"probability"`
	LikeCountToday int     `json:"like_count_today"`
}

type StoryCreateReq {
	CharacterId string `json:"character_id"` // 发布角色（owner 为当前登录用户）
}

type StoryCreateResp {
	StoryIds []string `json:"story_ids"` // 创建的 story_id 列表（无 draft，创建即 published；AIGC 一次可生成多条排在未来不同时刻）
}

@server (
	jwt:      Auth
	authType: apiKey
	group:    story
	tags:     "限时动态（story）"
	timeout:  300s
)
service arca_api {
	// feed 顶部 headline 横滚：按角色聚合最近 24h 内未过期 story，含 unread / story_count / latest_published_at
	@handler StoryHeadline
	get /story/headline returns (StoryHeadlineResp)

	// 全屏 viewer：返回单个角色窗口内全部 story（按 published_at 升序），含 viewed / liked
	@handler StoryViewer
	get /story/viewer (StoryViewerReq) returns (StoryViewerResp)

	// 已读上报：滑动间隔幂等写 user_story_view
	@handler StoryViewMark
	post /story/view/mark (StoryViewMarkReq) returns (StoryViewMarkResp)

	// 评论：5s 内同一 story 同一用户的多条文本合并为同一对话，触发 LLM 回复
	@handler StoryComment
	post /story/comment (StoryCommentReq) returns (StoryCommentResp)

	// 点赞：upsert user_story_like_reaction，按当日累计点赞数三档概率触发 LLM 回复
	@handler StoryLike
	post /story/like (StoryLikeReq) returns (StoryLikeResp)

	// 创建：用户主动让指定角色给自己发一条限时动态。异步——同步建 draft 占位立即返回 story_id，
	// 后台 arcaflow story_generate 调 AIGC character_action/post 生成内容回填发布（避免同步调 AIGC 慢导致 timeout）
	@handler StoryCreate
	post /story/create (StoryCreateReq) returns (StoryCreateResp)
}

type AppleLoginReq {
	IdentityToken string `json:"identity_token"`
	User          string `json:"user"`
	Email         string `json:"email,optional"`
	FullName      string `json:"full_name,optional"`
}

type AppleLoginResp {
	Token         *JwtTokenEntity `json:"token,optional,omitempty"` // 验证token
	TempAuthToken *string         `json:"auth_token,optional,omitempty"` // 临时认证token
}

type ImportRoleExportsTestCopyReq {
	SrcKey string `json:"src_key"` // 源 TOS 桶里的 object key；可填 tos_url（含 https://...）或纯 key
}

type ImportRoleExportsTestCopyResp {
	SrcBucket string `json:"src_bucket"` // 源桶名（来自 config.TosSource.Bucket）
	SrcKey    string `json:"src_key"` // 实际请求的 src key（去掉 host 后）
	DstBucket string `json:"dst_bucket"` // 目标桶名（来自 config.Tos.Bucket）
	DstKey    string `json:"dst_key"` // 写入目标桶的 key
	CdnUrl    string `json:"cdn_url"` // 拼好的 CDN URL（可直接浏览器打开验证）
	Bytes     int    `json:"bytes"` // 搬运对象字节数
}

type JwtTokenEntity {
	JwtToken  string `json:"jwt_token"`
	ExpiresIn int64  `json:"expires_in"`
}

type SendCodeReq {
	PhoneNumber string `json:"phone_number"` // 要发送验证码的手机号
	Scene       string `json:"scene,options=login|deregister"` // 场景，注册登录/注销
}

type SendCodeResp {
	Message    string   `json:"message"`
	RequestId  string   `json:"request_id"`
	MessageIds []string `json:"message_ids"`
}

type VerifyCodeReq {
	PhoneNumber   string  `json:"phone_number"` // 接收验证码的手机号
	Code          string  `json:"code"` // 用户输入的验证码
	Scene         string  `json:"scene,options=login|deregister"` // 场景，注册登录/注销
	TempAuthToken *string `json:"temp_auth_token,optional,omitempty"` // 三方登录临时认证token
}

type VerifyCodeResp {
	IsValid   bool   `json:"is_valid"`
	Message   string `json:"message"`
	RequestId string `json:"request_id,optional"`
	JwtToken  string `json:"jwt_token,optional"`
	ExpiresIn int    `json:"expires_in,optional"`
}

// ========================== user × character 好友关系（character 重构入口） ==========================
type AddFriendReq {
	CharacterId string `json:"character_id"`
}

type AddFriendResp {
	FriendshipId       string `json:"friendship_id"`
	CharacterSaveId    string `json:"character_save_id"`
	CharacterVersionNo int32  `json:"character_version_no"`
	IsNew              bool   `json:"is_new"`
}

type RemoveFriendReq {
	CharacterId string `json:"character_id"`
}

type RemoveFriendResp {
	Removed          bool `json:"removed"`
	RemovedSaveCount int  `json:"removed_save_count"`
}

type ListFriendshipReq {
	Cursor string `json:"cursor,optional"`
	Limit  int    `json:"limit,optional"`
}

type FriendshipItem {
	FriendshipId           string `json:"friendship_id"`
	CharacterId            string `json:"character_id"`
	CurrentCharacterSaveId string `json:"current_character_save_id"`
	CreatedAtMs            int64  `json:"created_at_ms"`
	UpdatedAtMs            int64  `json:"updated_at_ms"`
}

type ListFriendshipResp {
	Friends    []*FriendshipBasicInfo `json:"friends"` // 角色列表
	NextCursor string                 `json:"next_cursor"` // 下一个游标，如果没有更多数据则为空
	HasMore    bool                   `json:"has_more,optional"` // 是否还有更多数据
}

type UpdateFriendSaveVersionReq {
	CharacterSaveId    string `json:"character_save_id"` // 要更新的存档ID
	CharacterVersionNo int32  `json:"character_version_no"` // 目标版本号（character_version.version_no，须存在于该存档对应的角色）
}

type UpdateFriendSaveVersionResp {
	CharacterSaveId    string `json:"character_save_id"`
	CharacterVersionNo int32  `json:"character_version_no"` // 更新后绑定的版本号
	Updated            bool   `json:"updated"` // false = 本来就绑定在该版本（幂等）
}

@server (
	jwt:      Auth
	authType: apiKey
	group:    friendship
	tags:     "用户-角色好友关系"
	timeout:  30s
)
service arca_api {
	@handler addFriend
	post /friendship/add (AddFriendReq) returns (AddFriendResp)

	@handler removeFriend
	post /friendship/remove (RemoveFriendReq) returns (RemoveFriendResp)

	@handler listFriendship
	post /friendship/list (ListFriendshipReq) returns (ListFriendshipResp)

	@handler updateFriendSaveVersion
	post /friendship/update_save_version (UpdateFriendSaveVersionReq) returns (UpdateFriendSaveVersionResp)
}

// ========================== user_persona 用户自设 ==========================
type UserPersonaItem {
	PersonaId   string `json:"persona_id"`
	Name        string `json:"name"`
	Gender      string `json:"gender,optional"` // male / female / other
	Profile     string `json:"profile,optional"`
	Avatar      Media  `json:"avatar,optional"`
	IsDefault   bool   `json:"is_default"`
	CreatedAtMs int64  `json:"created_at_ms"`
	UpdatedAtMs int64  `json:"updated_at_ms"`
}

type CreateUserPersonaReq {
	Name      string `json:"name"` // 必填
	Gender    string `json:"gender,optional"`
	Profile   string `json:"profile,optional"`
	AvatarURL string `json:"avatar_url,optional"`
	IsDefault bool   `json:"is_default,optional"` // true 时会把该用户其他 default 取消（同事务保证 partial unique）
}

type CreateUserPersonaResp {
	Persona UserPersonaItem `json:"persona"`
}

type UpdateUserPersonaReq {
	PersonaId string  `json:"persona_id"` // 必填
	Name      *string `json:"name,optional,omitempty"`
	Gender    *string `json:"gender,optional,omitempty"`
	Profile   *string `json:"profile,optional,omitempty"`
	AvatarURL *string `json:"avatar_url,optional,omitempty"`
	IsDefault *bool   `json:"is_default,optional,omitempty"`
}

type UpdateUserPersonaResp {
	Persona UserPersonaItem `json:"persona"`
}

type DeleteUserPersonaReq {
	PersonaId string `json:"persona_id"`
}

type DeleteUserPersonaResp {
	Deleted bool `json:"deleted"`
}

type ListUserPersonasReq {}

type ListUserPersonasResp {
	Items []UserPersonaItem `json:"items"`
}

type ApplyUserPersonaReq {
	CharacterId string `json:"character_id"` // 应用到该 (user, character) 的 active save
	PersonaId   string `json:"persona_id,optional"` // 空串=取消应用（save.user_persona_id 置空）
}

type ApplyUserPersonaResp {
	CharacterSaveId string `json:"character_save_id"`
	PersonaId       string `json:"persona_id,optional"` // 应用后的 persona_id（取消时为空）
}

@server (
	jwt:      Auth
	authType: apiKey
	group:    user_persona
	tags:     "用户自设"
	timeout:  30s
)
service arca_api {
	@handler createUserPersona
	post /user_persona/create (CreateUserPersonaReq) returns (CreateUserPersonaResp)

	@handler updateUserPersona
	post /user_persona/update (UpdateUserPersonaReq) returns (UpdateUserPersonaResp)

	@handler deleteUserPersona
	post /user_persona/delete (DeleteUserPersonaReq) returns (DeleteUserPersonaResp)

	@handler listUserPersonas
	post /user_persona/list (ListUserPersonasReq) returns (ListUserPersonasResp)

	@handler applyUserPersona
	post /character_save/apply_persona (ApplyUserPersonaReq) returns (ApplyUserPersonaResp)
}

// ========================== character_save 聊天偏好 ==========================
type ChatModelOption {
	ModelId string `json:"model_id"`
	Name    string `json:"name"`
}

type ChatPreferenceOptions {
	Models             []ChatModelOption `json:"models"`
	DefaultModelId     string            `json:"default_model_id"`
	TemperatureMin     float64           `json:"temperature_min"` // 温度下限（0）
	TemperatureMax     float64           `json:"temperature_max"` // 温度上限（2）
	TemperatureDefault float64           `json:"temperature_default"` // 默认温度
}

type ChatPreferenceCurrent {
	ModelId       string  `json:"model_id"`
	Temperature   float64 `json:"temperature"` // 当前温度（0-2 小数）
	IsCustom      bool    `json:"is_custom"`
	BackgroundUrl string  `json:"background_url"`
	BubbleKey     string  `json:"bubble_key"`
}

type GetChatPreferenceReq {
	CharacterSaveID string `form:"character_save_id"`
}

type GetChatPreferenceResp {
	Options ChatPreferenceOptions `json:"options"`
	Current ChatPreferenceCurrent `json:"current"`
}

type SetChatPreferenceReq {
	CharacterId     string  `json:"character_id"`
	ModelId         string  `json:"model_id,optional"`
	Temperature     float64 `json:"temperature,default=-1"` // 温度（0-2 小数）；0 为合法值，缺省 -1 表示不修改
	BackgroundUrl   string  `json:"background_url,optional"`
	ClearBackground bool    `json:"clear_background,optional"`
	BubbleKey       string  `json:"bubble_key,optional"`
	ClearBubble     bool    `json:"clear_bubble,optional"`
}

type SetChatPreferenceResp {
	CharacterSaveId string  `json:"character_save_id"`
	ModelId         string  `json:"model_id"`
	Temperature     float64 `json:"temperature"`
	BackgroundUrl   string  `json:"background_url"`
	BubbleKey       string  `json:"bubble_key"`
}

@server (
	jwt:      Auth
	authType: apiKey
	group:    chat_preference
	tags:     "聊天偏好"
	timeout:  30s
)
service arca_api {
	@handler getChatPreference
	get /character_save/chat_preference (GetChatPreferenceReq) returns (GetChatPreferenceResp)

	@handler setChatPreference
	post /character_save/chat_preference/set (SetChatPreferenceReq) returns (SetChatPreferenceResp)
}

type RandomMatchCharacterReq {
	Tags []string `json:"tags"` // 用户自由输入的匹配标签，命中任一即可
}

type RandomMatchCharacterResp {
	ChatSessionID    string               `json:"chat_session_id"`
	AnonymousTags    []string             `json:"anonymous_tags"` // 对方角色匿名标签（唯一露出）
	GreetingMessages []PhoneMessageOutput `json:"greeting_messages,optional"` // 匹配成功后角色主动打招呼消息（aigc anon_chats type=greeting；失败时为空，不阻断匹配）
}

type SendMessageToAnonymousCharacterReq {
	ChatSessionID   string              `json:"chat_session_id"`
	ResendMessageId string              `json:"resend_message_id,optional"` // 重发的消息ID（可选，用于点击红点重发）
	Messages        []PhoneMessageInput `json:"messages"` // 用户发送的消息列表
}

type SendMessageToAnonymousCharacterResp {
	CurrentMessages      []PhoneMessageOutput `json:"current_messages"` // 用户发送的消息列表（带 cursor id）
	CharacterMessages    []PhoneMessageOutput `json:"character_messages"` // 角色回复的消息列表（可能有多条，每条都带 cursor id）
	FriendRequestPending bool                 `json:"friend_request_pending"` // 角色是否发起好友请求
}

type AnonymousAddFriendReq {
	ChatSessionID string `json:"chat_session_id"`
}

type AnonymousAddFriendResp {
	Accepted        bool   `json:"accepted"` // 角色是否接受好友申请（aigc anon_chats type=friend_request 判定）
	Message         string `json:"message,optional,omitempty"` // 角色判定留言（接受/拒绝都可能有）
	CharacterID     string `json:"character_id,optional,omitempty"` // accepted=true 转正后揭示真实身份
	CharacterSaveID string `json:"character_save_id,optional,omitempty"` // accepted=true 时返回
	FriendshipID    string `json:"friendship_id,optional,omitempty"` // accepted=true 时返回
}

type SetMyAnonymousTagsReq {
	Tags []string `json:"tags"` // 全量替换（首次设置即创建）；自由填写无枚举，去空去重后最多 10 个，传空数组即清空
}

type MyAnonymousTagsResp {
	Tags []string `json:"tags"` // 我的匿名标签（user.my_anonymous_tags），未设置时为空数组
}

@server (
	jwt:      Auth
	authType: apiKey
	group:    anonymous_chat
	tags:     "随机匹配"
	timeout:  30s
)
service arca_api {
	@handler randomMatchCharacter
	post /anonymous_chat/random_match (RandomMatchCharacterReq) returns (RandomMatchCharacterResp)

	@handler sendMessageToAnonymousCharacter
	post /anonymous_chat/send_message (SendMessageToAnonymousCharacterReq) returns (SendMessageToAnonymousCharacterResp)

	@handler addFriendFromAnonymousChat
	post /anonymous_chat/add_friend (AnonymousAddFriendReq) returns (AnonymousAddFriendResp)

	@handler setMyAnonymousTags
	post /anonymous_chat/my_tags/set (SetMyAnonymousTagsReq) returns (MyAnonymousTagsResp)

	@handler getMyAnonymousTags
	post /anonymous_chat/my_tags/get returns (MyAnonymousTagsResp)
}

// ============ 代币钱包与充值 ============
type WalletInfoResp {
	FreeTokens   int64 `json:"free_tokens"` // 免费币余额
	PaidTokens   int64 `json:"paid_tokens"` // 付费币余额
	FrozenTokens int64 `json:"forzen_tokens"` // 已冻结代币
	TotalTokens  int64 `json:"total_tokens"` // 可用合计（免费 + 付费）
	LowBalance   bool  `json:"low_balance"` // true：余额不够 N 次 chat 消费 → 前端限时气泡提示充值
	NextGrantAt  int64 `json:"next_grant_at"` // 下一次每日恢复发放UTC时间（unix 秒，UTC 自然日 0 点）；0=当前区域未启用每日恢复，前端隐藏倒计时
	ServerTime   int64 `json:"server_time"` // 服务器当前时间（unix 秒），前端用 next_grant_at - server_time 起倒计时，避免客户端时钟偏差
}

type WalletTransactionsReq {
	Cursor       int64  `json:"cursor,optional"` // 游标，首页传 0 或省略
	Limit        int64  `json:"limit,optional"` // 每页条数，默认 20、上限 100
	BillCategory string `json:"bill_category,options=income|expense"` // 流水分类
}

type WalletTransactionItem {
	ID        int64  `json:"id"`
	Source    string `json:"source"` // "free"（免费币流水）| "paid"（付费币流水）
	Type      int64  `json:"type"` // 流水类型（原始枚举值，保留）
	Kind      string `json:"kind"` // 可读流水类型：free→grant/consume/free_quota/adjust；paid→recharge/consume/refund/adjust；未知→unknown
	Scene     string `json:"scene"` // 消费场景，如 chat / gen_image
	BizID     string `json:"biz_id"` // 业务幂等键
	Amount    int64  `json:"amount"` // 变动量（消费为负、入账为正）
	CreatedAt int64  `json:"created_at"` // unix 秒
}

type WalletTransactionsResp {
	BillCategory string                  `json:"bill_category,options=income|expense"` // 流水分类
	Items        []WalletTransactionItem `json:"items"`
	NextCursor   string                  `json:"next_cursor"` // 空字符串表示没有更多
}

type RechargeCreateReq {
	PackageID string `json:"package_id"` // 充值套餐 id
	Provider  string `json:"provider,optional"` // 渠道：apple_iap / google_play / stripe / mock；省略默认 mock
}

type RechargeCreateResp {
	OrderID         string `json:"order_id"` // 内部订单 id
	OutOrderID      string `json:"out_order_id"` // 外部订单号
	ProductID       string `json:"product_id"` // 该渠道商品 id（端上据此发起支付）
	ClientSecret    string `json:"client_secret,optional"` // 仅 Stripe 返回：前端用其调 PaymentSheet/confirmPayment 完成付款
	PaymentIntentID string `json:"payment_intent_id,optional"` // 仅 Stripe 返回：PaymentIntent id（pi_...）
}

type RechargeVerifyReq {
	OrderID   string `json:"order_id"`
	Receipt   string `json:"receipt"` // IAP receipt / Apple JWS / Google INAPP_PURCHASE_DATA / Stripe payment_intent_id
	Signature string `json:"signature,optional"` // 仅 Google Play 需要（INAPP_DATA_SIGNATURE），其它渠道留空
}

type RechargeVerifyResp {
	Status     string `json:"status"` // "paid"
	FreeTokens int64  `json:"free_tokens"` // 入账后免费币余额
	PaidTokens int64  `json:"paid_tokens"` // 入账后付费币余额
}

type RechargePackageItem {
	PackageID        string            `json:"package_id"` // 传给 /pay/recharge/create 的套餐 id
	Name             string            `json:"name"` // 展示名，如“100 代币”
	Tokens           int64             `json:"tokens"` // 基础代币数
	BonusTokens      int64             `json:"bonus_tokens"` // 赠送代币数
	ProviderProducts map[string]string `json:"provider_products"` // 渠道→商品id（apple_iap/google_play/stripe→product_id），客户端据此向平台下单 + 取本地化价
	SortOrder        int64             `json:"sort_order"` // 展示排序（升序）
}

type RechargePackagesResp {
	Packages []RechargePackageItem `json:"packages"` // 当前用户区域可购买的套餐（enabled + region 过滤，按 sort_order 升序）
}

type RechargeOrdersReq {
	Cursor int64 `form:"cursor,optional"` // 游标：上一页最后一条 order_id；首页 0 / 省略
	Limit  int64 `form:"limit,optional"` // 每页条数，默认 20、上限 100
	Status int64 `form:"status,optional"` // 状态筛选：0 / 省略 = 全部；1 待支付 2 已支付 3 失败 4 已退款 5 部分退款 6 已过期
}

type RechargeOrderItem {
	OrderID       string `json:"order_id"`
	OutOrderID    string `json:"out_order_id"`
	PackageID     string `json:"package_id"`
	Provider      string `json:"provider"` // apple_iap / google_play / stripe / mock
	ProductID     string `json:"product_id"`
	TokenAmount   int64  `json:"token_amount"` // 该单代币数（含 bonus）
	PriceAmount   int64  `json:"price_amount"` // 价格（最小货币单位，如分）；IAP 平台计价时可能为 0
	PriceCurrency string `json:"price_currency"`
	Status        int64  `json:"status"` // 1 待支付 2 已支付 3 失败 4 已退款 5 部分退款 6 已过期
	CreatedAt     int64  `json:"created_at"` // unix 秒
	PaidAt        int64  `json:"paid_at"` // unix 秒；0 = 未支付
	ProviderTxID  string `json:"provider_tx_id"` // 渠道交易号（未支付为空）
	OriginalTxID  string `json:"original_tx_id"` // 渠道原始交易号（IAP 续期/恢复场景，无则为空）
}

type RechargeOrdersResp {
	Orders     []RechargeOrderItem `json:"orders"`
	NextCursor string              `json:"next_cursor"` // 空字符串 = 没有更多
}

// 功能点免费次数余量（GET /wallet/free_quotas）
type FreeQuotaItem {
	Scene     string `json:"scene"` // 功能点场景，如 chat / gen_image
	FreeCount int64  `json:"free_count"` // 当前区域每日免费次数配额
	Used      int64  `json:"used"` // 今日（UTC 自然日）已用次数
	Remaining int64  `json:"remaining"` // 今日剩余次数（max(0, free_count-used)）
}

type FreeQuotasResp {
	FreeQuotas []FreeQuotaItem `json:"free_quotas"` // 仅含 enabled 且 free_count>0 的场景，按 scene 升序
}

// 退款明细（GET /pay/recharge/refunds，游标分页）
type RechargeRefundsReq {
	Cursor int64 `form:"cursor,optional"` // 游标：上一页最后一条 refund_id；首页 0 / 省略
	Limit  int64 `form:"limit,optional"` // 每页条数，默认 20、上限 100
}

type RechargeRefundItem {
	RefundID         string `json:"refund_id"`
	OrderID          string `json:"order_id"`
	OutOrderID       string `json:"out_order_id"` // 所属订单的外部订单号
	RefundTokens     int64  `json:"refund_tokens"` // 退还代币数
	RefundPrice      int64  `json:"refund_price"` // 退款金额（最小货币单位，如分）
	RefundCurrency   string `json:"refund_currency"`
	ProviderRefundID string `json:"provider_refund_id"` // 渠道退款号（无则为空）
	Reason           string `json:"reason"` // 退款原因
	CreatedAt        int64  `json:"created_at"` // unix 秒
}

type RechargeRefundsResp {
	Refunds    []RechargeRefundItem `json:"refunds"`
	NextCursor string               `json:"next_cursor"` // 空字符串 = 没有更多
}

// 单订单详情（GET /pay/recharge/order，含该单退款明细）
type RechargeOrderDetailReq {
	OrderID int64 `form:"order_id"` // 内部订单 id
}

type RechargeOrderDetailResp {
	Order   RechargeOrderItem    `json:"order"` // 订单（仅限当前用户本人）
	Refunds []RechargeRefundItem `json:"refunds"` // 该单退款明细（按 refund_id 倒序），无则空数组
}

@server (
	jwt:      Auth // 开启 jwt 认证（需登录）
	authType: apiKey
	tags:     "代币钱包与充值"
)
service arca_api {
	// 钱包余额（三档：免费币 / 付费币 / 欠款）
	@handler walletInfo
	get /wallet/info returns (WalletInfoResp)

	// 钱包流水（倒序、游标分页）
	@handler walletTransactions
	post /wallet/transactions (WalletTransactionsReq) returns (WalletTransactionsResp)

	// 充值套餐列表（当前用户区域可购买；前端据此取 package_id + 各渠道 product_id）
	@handler rechargePackages
	get /pay/recharge/packages returns (RechargePackagesResp)

	// 充值建单（查套餐 → 落 pending 订单 → 返回渠道商品 id）
	@handler rechargeCreate
	post /pay/recharge/create (RechargeCreateReq) returns (RechargeCreateResp)

	// 充值验签入账（验渠道凭证 → 订单置 paid → 钱包入账，幂等）
	@handler rechargeVerify
	post /pay/recharge/verify (RechargeVerifyReq) returns (RechargeVerifyResp)

	// 充值订单历史（当前用户，倒序、游标分页，可按状态筛选）
	@handler rechargeOrders
	get /pay/recharge/orders (RechargeOrdersReq) returns (RechargeOrdersResp)

	// 功能点免费次数余量（当前用户，今日 UTC 自然日窗口；仅含启用且配额>0 的场景）
	@handler walletFreeQuotas
	get /wallet/free_quotas returns (FreeQuotasResp)

	// 退款明细（当前用户全部订单的退款记录，倒序、游标分页）
	@handler rechargeRefunds
	get /pay/recharge/refunds (RechargeRefundsReq) returns (RechargeRefundsResp)

	// 单订单详情（当前用户本人订单 + 该单退款明细）
	@handler rechargeOrderDetail
	get /pay/recharge/order (RechargeOrderDetailReq) returns (RechargeOrderDetailResp)
}

@server (
	jwt:      Auth // 开启 jwt 认证（需登录）
	authType: apiKey
	tags:     "表情包模块"
)
service arca_api {
	//============ 聊天窗表情包面板（平台 PGC pack + 用户 UGC 上传） =============
	// 拉取表情面板：最近使用 + 我的上传 + 平台表情包
	@handler listEmojiPanel
	post /emoji/panel (ListEmojiPanelReq) returns (ListEmojiPanelResp)

	// 上传用户表情（同步审核，不过返回错误且不落库）
	@handler uploadUserEmoji
	post /emoji/upload (UploadUserEmojiReq) returns (UploadUserEmojiResp)

	// 删除自己上传的表情（软删）
	@handler deleteUserEmoji
	post /emoji/delete (DeleteUserEmojiReq) returns (DeleteUserEmojiResp)

	// 标记表情为"最近使用"（客户端发送表情后调用）
	@handler markEmojiUsed
	post /emoji/mark_used (MarkEmojiUsedReq) returns (MarkEmojiUsedResp)
}

type ListMusicResp {
	Musics []MusicInfo `json:"recent"` // 最近使用
}

type MusicInfo {
	MusicKey string `json:"music_key"`
	Title    string `json:"title,optional"`
	Media    *Media `json:"media,optional"`
}

@server (
	jwt:      Auth // 开启 jwt 认证（需登录）
	authType: apiKey
	tags:     "资源模块"
)
service arca_api {
	@handler getMusicList
	get /resource/music_list returns (ListMusicResp)
}

