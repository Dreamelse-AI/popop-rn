type DemoCreateCharacterOpeninglogReq {
	Endpoint          string               `json:"endpoint,optional"`
	Name              string               `json:"name"` // 角色姓名
	Title             string               `json:"title"` // 角色称号
	Gender            string               `json:"gender"` // 性别
	Species           string               `json:"species"` // 物种
	Relations         []*CharacterRelation `json:"relations,optional"` // 关系列表（替代原来的relationship字段）
	Profile           string               `json:"profile"` // 人物设定/性格背景
	Timestamp         string               `json:"timestamp"` // 生成请求的时间戳
	ReferenceImageUrl string               `json:"reference_image_url"` // 参考图像URL
}

type DemoCreateCharacterOpeninglogResp {
	CharacterId  string `json:"character_id"`
	OpeningLogId string `json:"opening_log_id"`
}

// 不鉴权，不开放外网访问
@server (
	tags:    "（无鉴权）内部接口-工具"
	timeout: 0s
)
service arca_api {
	// 生成JWT Token
	@handler internalToolGenJwtToken
	post /internal/tool/gen_jwt_token (InternalToolGenJwtTokenReq) returns (InternalToolGenJwtTokenResp)

	// 联调：模拟上报 App 状态（body 含 user_id/device_id，逻辑同 /app/report_app_state）
	@handler internalToolMockReportAppState
	post /internal/tool/mock_report_app_state (InternalToolMockReportAppStateReq) returns (ReportAppStateResp)
}

// 定时打印请求（测试 arcaflow：POST 时间 + msg，到时在 arcaflow 中打印，无需鉴权）
type ScheduledPrintReq {
	Time string `json:"time"` // 触发时间：RFC3339、或 "2006-01-02 15:04:05"、或 Unix 秒时间戳
	Msg  string `json:"msg"` // 到时在 arcaflow 日志中打印的内容
}

// 定时打印响应
type ScheduledPrintResp {
	TaskId      string `json:"task_id"` // 任务 ID
	TriggerTime string `json:"trigger_time"` // 触发时间（RFC3339）
	Message     string `json:"message"` // 说明：立即提交或已加入延时队列
}

// 不鉴权，测试 arcaflow 正确性
@server (
	tags: "（无鉴权）测试-arcaflow 定时打印"
)
service arca_api {
	// 提交定时打印任务：到时在 arcaflow 中打印 msg
	@handler scheduledPrint
	post /api/test/scheduled_print (ScheduledPrintReq) returns (ScheduledPrintResp)
}

// 内部工具：模拟客户端上报 App 状态（无需 JWT，由 body 指定用户与设备）
type InternalToolMockReportAppStateReq {
	UserId    string `json:"user_id"` // 用户 ID，必填
	DeviceId  string `json:"device_id"` // 设备 ID，必填
	AppState  string `json:"app_state,options=foreground|background"` // 前台/后台
	EventType string `json:"event_type,optional,options=heartbeat|page_enter|page_leave|app_exit"`
	PageName  string `json:"page_name,optional"`
	PagePath  string `json:"page_path,optional"`
	SessionID string `json:"session_id,optional"`
	ClientTs  int64  `json:"client_ts,optional"`
	IsExit    bool   `json:"is_exit,optional"`
}

// 生成JWT Token请求（内部工具接口）
type InternalToolGenJwtTokenReq {
	Uid       string `json:"uid"` // 用户ID，必填
	Did       string `json:"did,optional"` // 设备ID，可选
	ExpiresIn int64  `json:"expires_in,optional"` // JWT令牌过期时间（秒），可选，默认30天
}

// 生成JWT Token响应（内部工具接口）
type InternalToolGenJwtTokenResp {
	JwtToken   string `json:"jwt_token"` // JWT令牌
	HelpHeader string `json:"help_header,optional"` // 参考用的Header字段，供参考
	ExpiresIn  int64  `json:"expires_in"` // JWT令牌过期时间（秒），默认30天
}

// 获取临时TOS上传凭证请求
type GetTosUploadCredentialReq {
	ExpiresIn int64 `json:"expires_in,optional"` // 凭证过期时间（秒），可选
}

// 获取临时TOS上传凭证响应
type GetTosUploadCredentialResp {
	AccessKeyId     string `json:"access_key_id"` // 临时访问密钥ID
	SecretAccessKey string `json:"secret_access_key"` // 临时访问密钥
	SessionToken    string `json:"session_token"` // 临时会话令牌
	Bucket          string `json:"bucket"` // 存储桶名称
	Region          string `json:"region"` // 区域
	Endpoint        string `json:"endpoint"` // 服务端点
	ExpiresIn       int64  `json:"expires_in"` // 凭证过期时间（秒）
}

type AuditImageReq {
	AuditUrl string `json:"audit_url"`
}

type AuditImageResp {
