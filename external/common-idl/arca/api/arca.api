@server (
	jwt:      Auth // 开启 jwt 认证
	authType: apiKey
	tags:     "用户模块"
	timeout:  5s
)
service arca_api {
	// 查询用户信息
	@handler getUserInfo
	post /user/get_user_info (GetUserInfoReq) returns (GetUserInfoResp)

	// 用户信息修改
	@handler updateUserInfo
	post /user/update_user_info (UpdateUserInfoReq) returns (UpdateUserInfoResp)

	// 用户“我的”页面统计信息
	@handler getUserHomePageStat
	post /user/get_home_page_stat (GetUserHomePageStatReq) returns (GetUserHomePageStatResp)

	// 注销当前账号（软删，JWT 鉴权）
	@handler deregister
	delete /user/account (DeregisterReq) returns (DeregisterResp)
}

